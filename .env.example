# ★ Server Only (절대 NEXT_PUBLIC_ 붙이지 않음)

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bdr_platform_development"
# Prisma direct connection (connection pooler 우회)
DIRECT_URL="postgresql://user:password@localhost:5432/bdr_platform_development"

# JWT (최소 32자 이상 랜덤 문자열 필수)
# 생성: openssl rand -base64 32
JWT_SECRET="minimum-32-characters-long-secret-key-here"

# NextAuth (최소 32자 이상)
NEXTAUTH_SECRET="another-32-characters-long-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Upstash Redis (Rate Limiting)
# 미설정 시 인메모리 fallback 사용 (개발환경 OK, 프로덕션 필수)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Monitoring
SENTRY_DSN=""

# CORS: 개발 환경 http://localhost:3000, 프로덕션 https://mybdr.kr
# 절대 "*" 사용 금지 (와일드카드는 보안 취약점)
CORS_ORIGIN="http://localhost:3000"

# ★ Client (브라우저 노출 OK)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Kakao Maps JavaScript SDK appkey (도메인 화이트리스트로 보호 — 브라우저 노출 OK)
# 카카오 디벨로퍼스에서 JavaScript 키 발급 후 운영/프리뷰 도메인 등록 필수
# 미설정 시 코트 지도 컴포넌트가 폴백 키 사용 + 콘솔 경고
NEXT_PUBLIC_KAKAO_MAPS_KEY=""

# 빌드 CI에서만 사용 (프로덕션에서 절대 설정 금지)
# SKIP_ENV_VALIDATION=true
