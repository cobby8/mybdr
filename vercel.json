{
  "buildCommand": "prisma generate && NODE_OPTIONS='--max-old-space-size=8192' next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/tournament-reminders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/web/youtube/recommend",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/expire-pending-bookings",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/game-report-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/lineup-reminder",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/stale-pending-fix",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/youtube-auto-match",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/series-counter-audit",
      "schedule": "0 0 1 * *"
    }
  ]
}
