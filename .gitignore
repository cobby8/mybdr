# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*

# next.js
/.next/
/out/

# production
/build

# env files (★ 보안: 절대 커밋하지 않음)
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# debug
npm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
prisma/migrations/

# IDE
.idea/
.vscode/

# OS
.DS_Store

# Office / 한글 임시 lock 파일 (문서 편집 중 자동 생성)
~$*

# outputs (기획 산출물 — 별도 관리)
/outputs/

# DB dump (보안: 커밋 금지)
local_dump.sql
*.sql.dump

# PWA: Serwist 빌드 산출물 (build-time generated)
/public/sw.js
/public/swe-worker-*.js

# Vercel local env (보안: 커밋 금지)
.env.vercel.local

# Playwright MCP (도구 산출물)
.playwright-mcp/

# 디자인 원본 (.ai 등 — 로컬 보관, git 추적 제외)
/참가팀_로고모음/
tmp/
!tmp/.gitkeep

# Playwright storageState (세션 쿠키, 민감) — .gitkeep은 유지
.auth/*.json
.auth/chrome-profile/
.auth/logs/
!.auth/.gitkeep
test-results/

# 모바일 감사 자동 생성 보고서 (.gitkeep만 추적)
Dev/design/audit-results/*
!Dev/design/audit-results/.gitkeep

# Design 시안 backup 파일 (Claude.ai Project 자동 백업)
Dev/design/BDR-current/**/*.backup.jsx
