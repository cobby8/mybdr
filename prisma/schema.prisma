  teams_team_member_histories_to_team_idToteams      Team?    @relation("team_member_histories_to_team_idToteams", fields: [to_team_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_e269e22032")

  @@index([action], map: "index_team_member_histories_on_action")
  @@index([from_team_id], map: "index_team_member_histories_on_from_team_id")
  @@index([processed_by_id], map: "index_team_member_histories_on_processed_by_id")
  @@index([team_id], map: "index_team_member_histories_on_team_id")
  @@index([team_id, action], map: "index_team_member_histories_on_team_id_and_action")
  @@index([to_team_id], map: "index_team_member_histories_on_to_team_id")
  @@index([user_id], map: "index_team_member_histories_on_user_id")
  @@index([user_id, created_at], map: "index_team_member_histories_on_user_id_and_created_at")
}

model tournament_series {
  id                BigInt         @id @default(autoincrement())
  uuid              String         @unique(map: "index_tournament_series_on_uuid") @db.VarChar
  name              String         @db.VarChar
  slug              String         @unique(map: "index_tournament_series_on_slug") @db.VarChar
  description       String?
  logo_url          String?        @db.VarChar
  organizer_id      BigInt
  status            String?        @default("active") @db.VarChar
  is_public         Boolean?       @default(true)
  settings          Json?          @default("{}")
  tournaments_count Int?           @default(0)
  created_at        DateTime       @db.Timestamp(6)
  updated_at        DateTime       @db.Timestamp(6)
  organization_id   BigInt?
  users             User           @relation(fields: [organizer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_65d50a1bc6")
  organization      organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tournaments       Tournament[]

  @@index([is_public], map: "index_tournament_series_on_is_public")
  @@index([organization_id], map: "index_tournament_series_on_organization_id")
  @@index([organizer_id], map: "index_tournament_series_on_organizer_id")
  @@index([status], map: "index_tournament_series_on_status")
}

model user_favorite_courts {
  id           BigInt    @id @default(autoincrement())
  user_id      BigInt
  court_id     BigInt
  nickname     String?   @db.VarChar
  use_count    Int       @default(0)
  position     Int?      @default(0)
  last_used_at DateTime? @db.Timestamp(6)
  created_at   DateTime  @db.Timestamp(6)
  updated_at   DateTime  @db.Timestamp(6)
  courts       courts    @relation(fields: [court_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_64d0010263")
  users        User      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_f0457391fc")

  @@unique([user_id, court_id], map: "index_user_favorite_courts_on_user_id_and_court_id")
  @@index([court_id], map: "index_user_favorite_courts_on_court_id")
  @@index([user_id], map: "index_user_favorite_courts_on_user_id")
  @@index([user_id, position], map: "index_user_favorite_courts_on_user_id_and_position")
  @@index([user_id, use_count], map: "index_user_favorite_courts_on_user_id_and_use_count")
}

model plans {
  id                 BigInt               @id @default(autoincrement())
  name               String               @db.VarChar
  description        String?              @db.VarChar
  plan_type          String               @default("monthly") @db.VarChar
  feature_key        String               @db.VarChar
  price              Int
  max_uses           Int?
  is_active          Boolean              @default(true)
  created_at         DateTime             @default(now()) @db.Timestamp(6)
  updated_at         DateTime             @updatedAt @db.Timestamp(6)
  user_subscriptions user_subscriptions[]

  @@map("plans")
}

model user_subscriptions {
  id          BigInt    @id @default(autoincrement())
  user_id     BigInt
  plan_id     BigInt
  feature_key String    @db.VarChar
  status      String    @default("active") @db.VarChar
  started_at  DateTime  @default(now()) @db.Timestamp(6)
  expires_at  DateTime? @db.Timestamp(6)
  payment_key String?   @db.VarChar
  order_id    String?   @db.VarChar
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  updated_at  DateTime  @updatedAt @db.Timestamp(6)
  users       User      @relation(fields: [user_id], references: [id])
  plans       plans     @relation(fields: [plan_id], references: [id])

  @@index([user_id, feature_key])
  @@map("user_subscriptions")
}

model site_settings {
  key        String   @id @db.VarChar
  value      String   @default("") @db.Text
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(6)

  @@map("site_settings")
}

model tournament_recorders {
  id           BigInt   @id @default(autoincrement())
  tournamentId String   @map("tournament_id") @db.Uuid
  recorderId   BigInt   @map("recorder_id")
  assignedBy   BigInt   @map("assigned_by")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  recorder   User       @relation("TournamentRecorder", fields: [recorderId], references: [id], onDelete: Cascade)
  assigner   User       @relation("TournamentRecorderAssigner", fields: [assignedBy], references: [id])

  @@unique([tournamentId, recorderId])
  @@index([tournamentId])
  @@index([recorderId])
  @@map("tournament_recorders")
}

model match_events {
  id            BigInt    @id @default(autoincrement())
  matchId       BigInt    @map("match_id")
  tournamentId  String    @map("tournament_id") @db.Uuid
  teamId        BigInt?   @map("team_id")
  playerId      BigInt?   @map("player_id")
  eventType     String    @map("event_type") @db.VarChar
  value         Int?
  quarter       Int?
  gameTime      String?   @map("game_time") @db.VarChar(10)
  clientEventId String?   @map("client_event_id") @db.VarChar(36)
  undone        Boolean   @default(false)
  undoneAt      DateTime? @map("undone_at") @db.Timestamptz(6)
  undoneBy      BigInt?   @map("undone_by")
  recordedBy    BigInt    @map("recorded_by")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  match    TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  recorder User            @relation("MatchEventRecorder", fields: [recordedBy], references: [id])
  undoner  User?           @relation("MatchEventUndoner", fields: [undoneBy], references: [id])

  @@index([matchId, undone])
  @@index([matchId, createdAt])
  @@index([tournamentId, teamId])
  @@map("match_events")
}

// 2026-05-02 회귀 방지 audit log (errors.md "양쪽 같은 팀 (피벗·아울스)" 케이스 대응)
// TournamentMatch 의 주요 필드 변경 이력 추적 — homeTeamId/awayTeamId/winner_team_id/status/score/scheduledAt
// source = "admin" (web admin PATCH) | "flutter" (v1 API) | "system" (progressDualMatch 등 자동)
model tournament_match_audits {
  id        BigInt   @id @default(autoincrement())
  matchId   BigInt   @map("match_id")
  changedAt DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)
  changedBy BigInt?  @map("changed_by") // userId — null 가능 (system/flutter 자동)
  source    String   @db.VarChar // "admin" | "flutter" | "system"
  context   String?  @db.VarChar // 호출 컨텍스트 (예: "progressDualMatch winner", "PATCH /matches/[matchId]")
  changes   Json // { field: { before, after }, ... }

  match   TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  changer User?           @relation("MatchAuditChanger", fields: [changedBy], references: [id])

  @@index([matchId, changedAt])
  @@index([changedBy, changedAt])
  @@map("tournament_match_audits")
}

model site_registrations {
  id            BigInt     @id @default(autoincrement())
  tournamentId  String     @map("tournament_id") @db.Uuid
  teamName      String     @map("team_name") @db.VarChar(100)
  captainName   String     @map("captain_name") @db.VarChar(50)
  captainPhone  String?    @map("captain_phone") @db.VarChar(20)
  captainEmail  String     @map("captain_email") @db.VarChar(100)
  playerCount   Int?       @map("player_count")
  message       String?
  status        String     @default("pending") @db.VarChar(20)
  processedAt   DateTime?  @map("processed_at") @db.Timestamp(6)
  processedNote String?    @map("processed_note")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamp(6)
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, captainEmail, teamName], map: "idx_site_registrations_unique")
  @@index([tournamentId, status])
  @@map("site_registrations")
}

// ─────────────────────────────────────────
// Phase 5: 픽업게임 모집 시스템
// 기존 games(팀매치/대회경기)와 분리 — 코트에서 즉석 참가하는 가벼운 경기
// ─────────────────────────────────────────
model pickup_games {
  id             BigInt   @id @default(autoincrement())
  court_info_id  BigInt // 코트 FK
  host_id        BigInt // 방장 (생성자)
  title          String   @db.VarChar(100) // 게임 제목
  description    String? // 추가 설명
  scheduled_date DateTime @db.Date // 경기 날짜
  start_time     String   @db.VarChar(5) // 시작 시간 (HH:mm)
  end_time       String?  @db.VarChar(5) // 종료 시간 (HH:mm, 선택)
  max_players    Int // 최대 인원
  skill_level    String?  @db.VarChar(20) // beginner | intermediate | advanced | any
  status         String   @default("recruiting") @db.VarChar(20) // recruiting | full | in_progress | completed | cancelled
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @updatedAt @db.Timestamp(6)

  // 관계
  court_infos  court_infos           @relation(fields: [court_info_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  host         User                  @relation("pickup_host", fields: [host_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  participants pickup_participants[]

  @@index([court_info_id, status], map: "idx_pickup_games_court_status")
  @@index([host_id], map: "idx_pickup_games_host")
  @@index([scheduled_date, status], map: "idx_pickup_games_date_status")
  @@index([status], map: "idx_pickup_games_status")
  @@index([scheduled_date], map: "idx_pickup_games_date") // 날짜별 픽업게임 조회
}

model pickup_participants {
  id             BigInt   @id @default(autoincrement())
  pickup_game_id BigInt // 픽업게임 FK
  user_id        BigInt // 참가자
  joined_at      DateTime @default(now()) @db.Timestamp(6) // 참가 시각

  // 관계
  pickup_game pickup_games @relation(fields: [pickup_game_id], references: [id], onDelete: Cascade)
  user        User         @relation("pickup_participant", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([pickup_game_id, user_id], map: "idx_pickup_participants_unique") // 중복 참가 방지
  @@index([user_id], map: "idx_pickup_participants_user")
}

// ─── 코트 앰배서더: 코트별 관리 권한을 가진 사용자 ───
// 앰배서더는 위키 수정을 승인 없이 직접 반영할 수 있고, 제보를 처리할 수 있다.
model court_ambassadors {
  id            BigInt    @id @default(autoincrement())
  user_id       BigInt // 신청/임명된 유저
  court_info_id BigInt // 대상 코트
  status        String    @default("pending") @db.VarChar // pending | active | revoked
  appointed_at  DateTime? @db.Timestamp(6) // 승인(임명) 시각
  revoked_at    DateTime? @db.Timestamp(6) // 해임 시각
  created_at    DateTime  @default(now()) @db.Timestamp(6) // 신청 시각
  updated_at    DateTime  @updatedAt @db.Timestamp(6)

  // 관계
  user        User        @relation("ambassador_user", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  court_infos court_infos @relation(fields: [court_info_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, court_info_id], map: "idx_court_ambassadors_user_court") // 유저당 코트 1건
  @@index([court_info_id, status], map: "idx_court_ambassadors_court_status")
  @@index([status], map: "idx_court_ambassadors_status")
  @@index([user_id], map: "idx_court_ambassadors_user") // 유저별 앰배서더 조회
}

// ─── 3x3 이벤트: 코트에서 열리는 3대3 대회/이벤트 ───
// 주최자가 이벤트를 만들고, 팀을 등록하고, 대진표를 생성하는 시스템
model court_events {
  id            BigInt   @id @default(autoincrement())
  court_info_id BigInt // 개최 코트
  organizer_id  BigInt // 주최자 (User FK)
  title         String   @db.VarChar(200) // 이벤트 제목
  description   String? // 설명
  event_date    DateTime @db.Date // 이벤트 날짜
  start_time    String?  @db.VarChar(5) // 시작 시간 (HH:mm)
  end_time      String?  @db.VarChar(5) // 종료 시간 (HH:mm)
  max_teams     Int      @default(8) // 최대 팀 수 (4/8/16)
  team_size     Int      @default(3) // 팀 인원 (기본 3명)
  format        String   @default("single_elimination") @db.VarChar(30) // single_elimination | round_robin
  status        String   @default("recruiting") @db.VarChar(20) // recruiting | ready | in_progress | completed | cancelled
  rules         String? // 경기 규칙 설명
  prize         String?  @db.VarChar(200) // 상금/상품 정보
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @updatedAt @db.Timestamp(6)

  // 관계
  court_info court_infos           @relation(fields: [court_info_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizer  User                  @relation("event_organizer", fields: [organizer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teams      court_event_teams[]
  matches    court_event_matches[]

  @@index([court_info_id, status], map: "idx_court_events_court_status")
  @@index([organizer_id], map: "idx_court_events_organizer")
  @@index([event_date, status], map: "idx_court_events_date_status")
}

// ─── 3x3 이벤트 팀: 이벤트에 참가하는 팀 ───
model court_event_teams {
  id         BigInt   @id @default(autoincrement())
  event_id   BigInt // 이벤트 FK
  team_name  String   @db.VarChar(100) // 팀명
  seed       Int? // 시드 번호 (대진표용)
  status     String   @default("registered") @db.VarChar(20) // registered | confirmed | eliminated | winner
  created_at DateTime @default(now()) @db.Timestamp(6)

  // 관계
  event        court_events          @relation(fields: [event_id], references: [id], onDelete: Cascade)
  players      court_event_players[]
  home_matches court_event_matches[] @relation("match_home_team")
  away_matches court_event_matches[] @relation("match_away_team")
  won_matches  court_event_matches[] @relation("match_winner_team")

  @@unique([event_id, team_name], map: "idx_court_event_teams_name") // 같은 이벤트 내 팀명 중복 방지
  @@index([event_id, status], map: "idx_court_event_teams_event_status")
  @@index([event_id], map: "idx_court_event_teams_event") // 이벤트별 팀 조회
}

// ─── 3x3 이벤트 선수: 팀에 소속된 선수 ───
model court_event_players {
  id            BigInt   @id @default(autoincrement())
  team_id       BigInt // 팀 FK
  user_id       BigInt // 선수 (User FK)
  jersey_number Int? // 등번호 (선택)
  is_captain    Boolean  @default(false) // 주장 여부
  joined_at     DateTime @default(now()) @db.Timestamp(6)

  // 관계
  team court_event_teams @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user User              @relation("event_player", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([team_id, user_id], map: "idx_court_event_players_unique") // 한 팀에 같은 유저 중복 방지
  @@index([user_id], map: "idx_court_event_players_user")
}

// ─── 3x3 이벤트 경기(대진표): 토너먼트 매치 ───
model court_event_matches {
  id             BigInt   @id @default(autoincrement())
  event_id       BigInt // 이벤트 FK
  round          Int // 라운드 (1=결승, 2=4강, 4=8강...)
  match_order    Int // 같은 라운드 내 순서 (1,2,3,4...)
  home_team_id   BigInt? // 홈팀 FK (미정이면 null)
  away_team_id   BigInt? // 어웨이팀 FK (미정이면 null)
  home_score     Int? // 홈팀 점수
  away_score     Int? // 어웨이팀 점수
  winner_id      BigInt? // 승리팀 FK
  status         String   @default("scheduled") @db.VarChar(20) // scheduled | in_progress | completed
  scheduled_time String?  @db.VarChar(5) // 예정 시간 (HH:mm)
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @updatedAt @db.Timestamp(6)

  // 관계
  event     court_events       @relation(fields: [event_id], references: [id], onDelete: Cascade)
  home_team court_event_teams? @relation("match_home_team", fields: [home_team_id], references: [id], onDelete: SetNull)
  away_team court_event_teams? @relation("match_away_team", fields: [away_team_id], references: [id], onDelete: SetNull)
  winner    court_event_teams? @relation("match_winner_team", fields: [winner_id], references: [id], onDelete: SetNull)

  @@unique([event_id, round, match_order], map: "idx_court_event_matches_round") // 라운드+순서 유니크
  @@index([event_id, status], map: "idx_court_event_matches_event_status")
}

// 웹 푸시 구독 정보 — 유저별 여러 기기(브라우저) 구독 가능
model push_subscriptions {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt // 구독 유저 FK
  endpoint   String   @db.VarChar // 브라우저가 생성한 푸시 엔드포인트 URL
  p256dh     String   @db.VarChar // 암호화 공개키
  auth       String   @db.VarChar // 인증 시크릿
  created_at DateTime @default(now()) @db.Timestamp(6)

  // 관계
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, endpoint], map: "idx_push_subscriptions_user_endpoint") // 유저+엔드포인트 중복 방지
  @@index([user_id], map: "idx_push_subscriptions_user_id")
}

// ===== 단체(Organization) 3단계 계층: 단체 → 시리즈 → 대회 =====

model organizations {
  id               BigInt    @id @default(autoincrement())
  uuid             String    @unique @default(uuid()) @db.VarChar
  name             String    @db.VarChar
  slug             String    @unique @db.VarChar
  logo_url         String?   @db.VarChar
  banner_url       String?   @db.VarChar
  description      String?
  region           String?   @db.VarChar // 활동 지역 (서울, 경기 등)
  contact_email    String?   @db.VarChar
  contact_phone    String?   @db.VarChar
  website_url      String?   @db.VarChar
  owner_id         BigInt // 단체 소유자 FK
  status           String    @default("approved") @db.VarChar // pending → approved/rejected
  is_public        Boolean   @default(true) // 공개 여부
  series_count     Int       @default(0) // 소속 시리즈 수 (캐시)
  // 승인 워크플로 필드
  approved_at      DateTime? @db.Timestamp(6) // 승인된 시각
  approved_by      BigInt? // 승인한 관리자 ID
  rejection_reason String? // 거절 사유
  rejection_at     DateTime? @db.Timestamp(6) // 거절 시각
  apply_note       String? // 신청 시 메모 (단체 목적 등)
  created_at       DateTime  @default(now()) @db.Timestamp(6)
  updated_at       DateTime  @updatedAt @db.Timestamp(6)

  // 관계
  owner   User                   @relation("org_owner", fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members organization_members[]
  series  tournament_series[]

  @@index([owner_id], map: "idx_organizations_owner_id")
  @@index([status], map: "idx_organizations_status")
  @@index([is_public], map: "idx_organizations_is_public")
  @@index([region], map: "idx_organizations_region")
}

model organization_members {
  id              BigInt   @id @default(autoincrement())
  organization_id BigInt // 단체 FK
  user_id         BigInt // 멤버 유저 FK
  role            String   @default("member") @db.VarChar // owner / admin / member
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamp(6)
  updated_at      DateTime @updatedAt @db.Timestamp(6)

  // 관계
  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, user_id], map: "idx_org_members_org_user")
  @@index([organization_id], map: "idx_org_members_organization_id")
  @@index([user_id], map: "idx_org_members_user_id")
}

// ===== 네이티브 광고 시스템 (MVP) =====

// 파트너사: 광고를 집행하는 업체/개인
model partners {
  id            BigInt   @id @default(autoincrement())
  uuid          String   @unique @default(uuid()) @db.VarChar
  name          String   @db.VarChar // 파트너사명
  logo_url      String?  @db.VarChar // 로고 이미지 URL
  website_url   String?  @db.VarChar // 홈페이지 URL
  contact_email String?  @db.VarChar // 담당자 이메일
  contact_phone String?  @db.VarChar // 담당자 연락처
  owner_id      BigInt // 등록한 유저 FK
  status        String   @default("pending") @db.VarChar // pending | approved | rejected | suspended
  description   String? // 파트너 소개
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @updatedAt @db.Timestamp(6)

  // 관계
  owner     User              @relation("partner_owner", fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members   partner_members[]
  campaigns ad_campaigns[]

  @@index([owner_id], map: "idx_partners_owner_id")
  @@index([status], map: "idx_partners_status")
}

// 파트너 멤버: 파트너사에 소속된 유저 (광고 관리 권한)
model partner_members {
  id         BigInt   @id @default(autoincrement())
  partner_id BigInt // 파트너사 FK
  user_id    BigInt // 유저 FK
  role       String   @default("member") @db.VarChar // owner | admin | member
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)

  // 관계
  partner partners @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([partner_id, user_id], map: "idx_partner_members_partner_user")
  @@index([partner_id], map: "idx_partner_members_partner_id")
  @@index([user_id], map: "idx_partner_members_user_id")
}

// 광고 캠페인: 파트너가 만든 광고 단위
model ad_campaigns {
  id             BigInt    @id @default(autoincrement())
  uuid           String    @unique @default(uuid()) @db.VarChar
  partner_id     BigInt // 파트너사 FK
  title          String    @db.VarChar // 광고 제목 (내부 관리용)
  headline       String    @db.VarChar // 표시될 제목
  description    String? // 광고 설명문
  image_url      String?   @db.VarChar // 광고 이미지 URL
  link_url       String    @db.VarChar // 클릭 시 이동할 URL
  cta_text       String?   @default("자세히 보기") @db.VarChar // CTA 버튼 텍스트
  status         String    @default("draft") @db.VarChar // draft | pending | approved | rejected | paused | ended
  // 게재 기간 (null이면 무기한)
  start_date     DateTime? @db.Date
  end_date       DateTime? @db.Date
  // 과금 관련 필드 (스키마만, 로직 미구현)
  budget         Decimal?  @db.Decimal(12, 2) // 총 예산
  spent          Decimal?  @default(0) @db.Decimal(12, 2) // 소진 금액
  pricing_type   String?   @default("cpm") @db.VarChar // cpm | cpc | flat
  price_per_unit Decimal?  @db.Decimal(10, 2) // 단가
  // 통계 (캐시 카운터)
  impressions    Int       @default(0) // 노출 수
  clicks         Int       @default(0) // 클릭 수
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  updated_at     DateTime  @updatedAt @db.Timestamp(6)

  // 관계
  partner    partners        @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  placements ad_placements[]

  @@index([partner_id], map: "idx_ad_campaigns_partner_id")
  @@index([status], map: "idx_ad_campaigns_status")
  @@index([start_date, end_date], map: "idx_ad_campaigns_date_range")
}

// 광고 배치: 어느 위치에 어떤 캠페인을 노출할지
model ad_placements {
  id          BigInt   @id @default(autoincrement())
  campaign_id BigInt // 캠페인 FK
  placement   String   @db.VarChar // feed | sidebar | court_top | list
  priority    Int      @default(0) // 높을수록 우선 노출
  is_active   Boolean  @default(true) // 활성 여부
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @updatedAt @db.Timestamp(6)

  // 관계
  campaign ad_campaigns @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@index([placement, is_active], map: "idx_ad_placements_placement_active")
  @@index([campaign_id], map: "idx_ad_placements_campaign_id")
}

model DuoSession {
  id           BigInt   @id @default(autoincrement())
  pin          String   @unique @db.VarChar(6)
  matchId      BigInt   @map("match_id")
  tournamentId String   @map("tournament_id") @db.Uuid
  hostUserId   BigInt   @map("host_user_id")
  guestUserId  BigInt?  @map("guest_user_id")
  hostTeam     String   @default("home") @map("host_team") @db.VarChar(10)
  status       String   @default("waiting") @db.VarChar(20)
  channelName  String   @map("channel_name") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@index([pin])
  @@index([tournamentId])
  @@index([status])
  @@map("duo_sessions")
}

// ============================================================================
// 심판 플랫폼 (Referee Platform) — 2026-04-12 Commit 1
// 6개 신규 모델: Association / AssociationAdmin / Referee / RefereeCertificate
//                / RefereeAssignment / RefereeSettlement
// 원칙: 기존 테이블 ALTER 0건. 신규 CREATE TABLE 6건만 발생.
// 운영 안전을 위해 users 수정은 `referee Referee?` back-relation 1줄뿐.
// ============================================================================

// 협회(Association): KBA / 17개 시도협회 / KBL / WKBL 계층형.
// self-relation으로 parent(상위 협회) ↔ children(하위 협회) 표현.
model Association {
  id          BigInt   @id @default(autoincrement())
  parent_id   BigInt? // null이면 최상위 조직 (KBA/KBL/WKBL)
  name        String   @db.VarChar // "서울특별시농구협회" 등 풀네임
  code        String   @unique @db.VarChar // "KBA", "KBA-11", "KBL", "WKBL" (upsert 기준)
  region_sido String?  @db.VarChar // "서울" 등. 전국조직은 null
  level       String   @db.VarChar // "national" | "sido" | "pro_league"
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @updatedAt @db.Timestamp(6)

  // 계층 구조: parent_id가 자기 자신의 id를 참조하는 self-FK
  parent        Association?             @relation("AssociationHierarchy", fields: [parent_id], references: [id], onDelete: NoAction)
  children      Association[]            @relation("AssociationHierarchy")
  referees      Referee[]
  admins        AssociationAdmin[]
  // 배정 워크플로우: 이 협회가 게시한 공고 + 일자별 선정 풀 역참조
  announcements AssignmentAnnouncement[]
  pools         DailyAssignmentPool[]
  // 정산 1차: 협회별 배정비 단가표 (1:1)
  fee_setting   AssociationFeeSetting?

  @@index([parent_id])
  @@index([level])
  @@index([region_sido])
  @@map("associations")
}

// 협회 관리자 매핑(옵션 B): users 테이블을 건드리지 않기 위한 매핑 테이블.
// User.admin_role = "association_admin" AND 이 매핑 행 존재 → 협회 관리자로 인식.
// user_id UNIQUE → 1인 1협회 강제.
model AssociationAdmin {
  id             BigInt   @id @default(autoincrement())
  user_id        BigInt   @unique // 한 유저는 하나의 협회만 관리 (1:1)
  association_id BigInt
  // v3: 협회 내 역할 (9종). 기본값 secretary_general — 기존 레코드에 자동 적용
  role           String   @default("secretary_general") @db.VarChar
  created_at     DateTime @default(now()) @db.Timestamp(6)

  association Association @relation(fields: [association_id], references: [id], onDelete: Cascade)
  // user 쪽은 단방향 FK만 — User 모델에 back-relation 추가하지 않음 (운영 안전)

  @@index([association_id])
  @@map("association_admins")
}

// 심판(Referee): User와 1:1. 실명/생년월일/전화 스냅샷을 따로 보관해 검증 변경 추적.
// v3: user_id nullable — 협회가 사전 등록 시 user_id 없이 생성, 이후 매칭으로 연결.
// onDelete: Cascade → User 삭제 시 Referee도 자동 삭제 (DB 레벨 무결성 보장).
model Referee {
  id             BigInt  @id @default(autoincrement())
  // v3: nullable — 사전 등록 시 user_id 없이 생성 가능 (매칭 후 채워짐)
  user_id        BigInt? @unique // User.id — 매칭 후 1인 1 Referee
  association_id BigInt? // 소속 협회 (없을 수도 있음)

  // 교차검증 스냅샷: User 변경돼도 이 값은 그대로 유지됨 (변경 감지에 사용)
  verified_name       String?   @db.VarChar
  verified_birth_date DateTime? @db.Date
  verified_phone      String?   @db.VarChar

  license_number String?  @unique @db.VarChar // 심판 자격번호(유니크)
  level          String?  @db.VarChar // beginner/intermediate/advanced/international
  role_type      String   @default("referee") @db.VarChar // referee/scorer/timer 등
  region_sido    String?  @db.VarChar
  region_sigungu String?  @db.VarChar
  status         String   @default("active") @db.VarChar // active/inactive/pending_review
  bio            String?
  joined_at      DateTime @default(now()) @db.Timestamp(6)
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @updatedAt @db.Timestamp(6)

  // ── v3 사전 등록 필드 ──────────────────────────────────
  // 협회가 입력한 원본 정보 (매칭 키로 사용)
  registered_name        String?   @db.VarChar // 관리자가 입력한 이름
  registered_phone       String?   @db.VarChar // 관리자가 입력한 전화번호
  registered_birth_date  DateTime? @db.Date // 관리자가 입력한 생년월일
  // 주민번호: 암호화 저장 (AES-256-GCM). 평문 절대 금지
  resident_id_enc        String? // 암호화된 주민번호 전체
  resident_id_last4      String?   @db.VarChar(4) // 뒷자리 4자리 (마스킹 표시용)
  // 매칭 상태: unmatched → matched (user_id 채워지면 자동 전환)
  match_status           String    @default("unmatched") @db.VarChar
  matched_at             DateTime? @db.Timestamp(6) // 매칭 완료 시각
  registered_by_admin_id BigInt? // 사전 등록한 관리자의 User.id
  // ── 사전 등록 필드 끝 ──────────────────────────────────

  // ── 정산 서류용 계좌 정보 ──
  bank_name    String? @db.VarChar // 은행명 (예: "국민은행")
  bank_account String? // 계좌번호 (암호화 저장)
  bank_holder  String? @db.VarChar // 예금주

  // v3: User optional — 사전 등록 시 user_id null 허용. onDelete: Cascade 유지.
  user         User?                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  association  Association?            @relation(fields: [association_id], references: [id], onDelete: SetNull)
  certificates RefereeCertificate[]
  assignments  RefereeAssignment[]
  settlements  RefereeSettlement[]
  documents    RefereeDocument[]
  // 배정 워크플로우: 심판이 제출한 신청 + 일자별 선정 풀 역참조
  applications AssignmentApplication[]
  pools        DailyAssignmentPool[]

  @@index([user_id])
  @@index([association_id])
  @@index([level])
  @@index([region_sido, region_sigungu])
  @@index([status])
  // v3: 매칭 검색용 인덱스
  @@index([match_status])
  @@index([registered_name, registered_phone])
  @@map("referees")
}

// 심판 자격증(RefereeCertificate): 한 심판이 여러 자격증 보유 가능.
// file_url은 1차 범위 제외. cert_number는 교차검증 키.
model RefereeCertificate {
  id                   BigInt    @id @default(autoincrement())
  referee_id           BigInt
  cert_type            String    @db.VarChar // referee/scorer/timer
  cert_grade           String    @db.VarChar // "1급", "2급", "3급", "국제" 등
  issuer               String    @db.VarChar // 발급 협회명 또는 code
  cert_number          String?   @db.VarChar // 교차검증 키 (없을 수 있음)
  issued_at            DateTime  @db.Date
  expires_at           DateTime? @db.Date // null이면 만료 없음
  verified             Boolean   @default(false) // admin 검증 여부
  verified_at          DateTime? @db.Timestamp(6)
  verified_by_admin_id BigInt? // 검증한 admin의 User.id (단방향)
  created_at           DateTime  @default(now()) @db.Timestamp(6)
  updated_at           DateTime  @updatedAt @db.Timestamp(6)

  referee Referee @relation(fields: [referee_id], references: [id], onDelete: Cascade)

  @@index([referee_id])
  @@index([cert_type, cert_grade])
  @@index([expires_at])
  @@index([cert_number])
  @@map("referee_certificates")
}

// 심판 배정(RefereeAssignment): 공식 대회 경기(TournamentMatch)에만 배정.
// v1 확정: game_id(일반 게임) 없음. tournament_match_id NOT NULL 단독.
model RefereeAssignment {
  id                  BigInt   @id @default(autoincrement())
  referee_id          BigInt
  tournament_match_id BigInt // tournament_matches.id (공식 대회 경기 전용)
  role                String   @db.VarChar // main/sub/recorder/timer
  status              String   @default("assigned") @db.VarChar // assigned/confirmed/declined/cancelled/completed
  assigned_at         DateTime @default(now()) @db.Timestamp(6)
  memo                String?
  created_at          DateTime @default(now()) @db.Timestamp(6)
  updated_at          DateTime @updatedAt @db.Timestamp(6)

  // 1차 추가: 일자별 선정 풀 연결 (SetNull로 기존 배정 무결성 유지)
  // 기존 RefereeAssignment는 pool 없이도 동작 — 2차에서 선정→배정 흐름 연결 시 사용
  pool_id BigInt?
  pool    DailyAssignmentPool? @relation(fields: [pool_id], references: [id], onDelete: SetNull)

  // 정산 1차 추가: 개별 배정비 (원 단위). null이면 협회 단가표(role별 기본값) 적용.
  // 이유: 일반 경기는 단가표로 충분하지만, 결승/특수 경기는 추가 수당 필요 → 행별 override 지원
  fee Int?

  referee    Referee            @relation(fields: [referee_id], references: [id], onDelete: Cascade)
  settlement RefereeSettlement?
  // tournament_match 쪽은 관계 선언 없음 — 기존 TournamentMatch 모델 미수정

  @@unique([referee_id, tournament_match_id]) // 같은 심판이 같은 경기에 중복 배정 방지
  @@index([referee_id])
  @@index([tournament_match_id])
  @@index([status])
  @@map("referee_assignments")
}

// 심판 정산(RefereeSettlement): 1 배정 = 1 정산 (assignment_id UNIQUE).
// amount는 원 단위 정수.
// 정산 1차: status 5종 확장(pending/scheduled/paid/cancelled/refunded) + scheduled_at 추가.
//   pending   — 최초 생성, 지급 전
//   scheduled — 지급 예정 등록
//   paid      — 지급 완료
//   cancelled — 배정 취소 등으로 정산 무효화
//   refunded  — 지급 이후 환수
model RefereeSettlement {
  id            BigInt    @id @default(autoincrement())
  referee_id    BigInt
  assignment_id BigInt    @unique // 1:1 (한 배정당 하나의 정산만)
  amount        Int // 원 단위
  status        String    @default("pending") @db.VarChar
  scheduled_at  DateTime? @db.Timestamp(6) // 지급 예정 등록 시각
  paid_at       DateTime? @db.Timestamp(6) // 지급 완료 시각
  memo          String?
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime  @updatedAt @db.Timestamp(6)

  referee    Referee           @relation(fields: [referee_id], references: [id], onDelete: Cascade)
  assignment RefereeAssignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)

  @@index([referee_id])
  @@index([status])
  @@map("referee_settlements")
}

// 협회 배정비 단가표(AssociationFeeSetting): 협회당 1행, 역할별 기본 배정비.
// 이유: 배정 생성 시 fee 필드가 비어있으면 role에 따라 이 표의 값을 자동 적용.
//       사무국장이 언제든 수정 가능. 새 배정에만 영향(기존 정산 금액 불변).
model AssociationFeeSetting {
  id             BigInt   @id @default(autoincrement())
  association_id BigInt   @unique // 1협회당 1행
  fee_main       Int      @default(80000) // 주심
  fee_sub        Int      @default(60000) // 부심
  fee_recorder   Int      @default(40000) // 기록
  fee_timer      Int      @default(40000) // 타이머
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @updatedAt @db.Timestamp(6)

  association Association @relation(fields: [association_id], references: [id], onDelete: Cascade)

  @@map("association_fee_settings")
}

// ── 심판 정산 서류(RefereeDocument): 자격증/신분증/통장 사본 등 정산에 필요한 서류 ──
// 이미지는 AES-256-GCM 암호화 후 DB에 base64로 저장. 파일 시스템/외부 스토리지 미사용.
// 1심판당 서류 종류별 1장만 허용 (@@unique).
model RefereeDocument {
  id             BigInt   @id @default(autoincrement())
  referee_id     BigInt
  doc_type       String   @db.VarChar // "certificate" | "id_card" | "bankbook"
  encrypted_data String // AES-256-GCM 암호화된 이미지 (base64)
  file_size      Int // 원본 바이트 수
  file_type      String   @db.VarChar // "image/jpeg" | "image/png" | "application/pdf"
  ocr_status     String   @default("pending") @db.VarChar // pending/completed/failed/skipped
  ocr_result     Json? // OCR 추출 결과 원본
  uploaded_by    BigInt // 업로드한 User.id (본인 또는 관리자)
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @updatedAt @db.Timestamp(6)

  referee Referee @relation(fields: [referee_id], references: [id], onDelete: Cascade)

  @@unique([referee_id, doc_type]) // 1심판당 서류 종류별 1장
  @@index([referee_id])
  @@map("referee_documents")
}

// ============================================================================
// 심판 배정 워크플로우 (1차: 공고 + 신청 + 선정풀 스켈레톤)
// ----------------------------------------------------------------------------
// 흐름:
//   1) 협회 팀장/총무가 AssignmentAnnouncement(공고) 게시 — 대회/일자/필요인원
//   2) 심판(또는 경기원)이 AssignmentApplication(신청) 제출 — 신청 일자 체크
//   3) [2차] 협회가 DailyAssignmentPool(일자별 선정 풀)로 확정
//   4) [2차] 풀 → RefereeAssignment(경기별 배정)로 내려감 (pool_id 연결)
// ============================================================================

// 배정 신청 공고 — 심판팀장/경기팀장이 게시
// tournament_id는 Tournament.id (UUID/String)
model AssignmentAnnouncement {
  id             BigInt     @id @default(autoincrement())
  tournament_id  String     @db.VarChar // Tournament.id (UUID)
  association_id BigInt // 게시 협회 (IDOR 필터 키)
  title          String     @db.VarChar
  description    String?    @db.Text
  role_type      String     @db.VarChar // "referee" | "game_official"
  // 공고 대상 일자들 (PostgreSQL Date[])
  dates          DateTime[] @db.Date
  // 일자별 필요 인원: {"YYYY-MM-DD": number}. 타임존 이슈 회피 위해 키는 문자열 고정
  required_count Json
  deadline       DateTime?  @db.Timestamp(6)
  status         String     @default("open") @db.VarChar // open/closed/cancelled
  created_by     BigInt // User.id (게시자)
  created_at     DateTime   @default(now()) @db.Timestamp(6)
  updated_at     DateTime   @updatedAt @db.Timestamp(6)

  association  Association             @relation(fields: [association_id], references: [id], onDelete: Cascade)
  applications AssignmentApplication[]

  @@index([tournament_id])
  @@index([association_id])
  @@index([status])
  @@map("assignment_announcements")
}

// 배정 신청 — 심판/경기원이 공고에 신청
// @@unique: 한 심판이 같은 공고에 중복 신청 방지
model AssignmentApplication {
  id              BigInt   @id @default(autoincrement())
  announcement_id BigInt
  referee_id      BigInt
  memo            String?  @db.Text
  status          String   @default("submitted") @db.VarChar // submitted/withdrawn
  created_at      DateTime @default(now()) @db.Timestamp(6)
  updated_at      DateTime @updatedAt @db.Timestamp(6)

  announcement AssignmentAnnouncement      @relation(fields: [announcement_id], references: [id], onDelete: Cascade)
  referee      Referee                     @relation(fields: [referee_id], references: [id], onDelete: Cascade)
  dates        AssignmentApplicationDate[]

  @@unique([announcement_id, referee_id])
  @@index([referee_id])
  @@map("assignment_applications")
}

// 신청 일자 (N:M) — 한 신청이 여러 일자를 선택 가능
model AssignmentApplicationDate {
  id             BigInt   @id @default(autoincrement())
  application_id BigInt
  date           DateTime @db.Date
  created_at     DateTime @default(now()) @db.Timestamp(6)

  application AssignmentApplication @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@unique([application_id, date])
  @@index([date])
  @@map("assignment_application_dates")
}

// 일자별 선정 풀 (2차에서 본격 사용, 1차에서는 모델만 생성)
// 협회 관리자가 신청자 중 특정 일자에 "이 심판을 쓴다"고 확정하는 단계
model DailyAssignmentPool {
  id             BigInt   @id @default(autoincrement())
  tournament_id  String   @db.VarChar
  association_id BigInt
  date           DateTime @db.Date
  referee_id     BigInt
  role_type      String   @db.VarChar // "referee" | "game_official"
  is_chief       Boolean  @default(false) // 주심/팀장 여부 (2차에서 활용)
  selected_by    BigInt // User.id (선정한 관리자)
  memo           String?  @db.Text
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @updatedAt @db.Timestamp(6)

  association Association         @relation(fields: [association_id], references: [id], onDelete: Cascade)
  referee     Referee             @relation(fields: [referee_id], references: [id], onDelete: Cascade)
  // 이 풀에서 내려간 경기별 배정들 (2차에서 연결)
  assignments RefereeAssignment[]

  @@unique([tournament_id, date, referee_id, role_type])
  @@index([tournament_id, date])
  @@index([association_id])
  @@map("daily_assignment_pools")
}

// ============================================================================
// 헬스체크 봇 — 2026-04-13 1차
// HealthCheckRun   : 1회 실행 세션 (cron/manual 트리거)
// HealthCheckResult: 각 체크 항목별 결과 (패스/실패 + 에러 메시지)
// 운영 안전: 신규 CREATE TABLE 2건만 발생. 기존 테이블 ALTER 0건.
// ============================================================================

// 헬스체크 1회 실행 세션. hourly/daily/manual 트리거 구분.
// status: running → passed/failed/partial 로 최종화
model HealthCheckRun {
  id            BigInt    @id @default(autoincrement())
  run_type      String    @db.VarChar // hourly/daily/manual
  started_at    DateTime  @default(now()) @db.Timestamp(6)
  finished_at   DateTime? @db.Timestamp(6)
  status        String    @default("running") @db.VarChar // running/passed/failed/partial
  total_checks  Int       @default(0)
  passed_checks Int       @default(0)
  failed_checks Int       @default(0)
  duration_ms   Int?
  triggered_by  String    @default("cron") @db.VarChar // cron/manual/admin 등

  checks HealthCheckResult[]

  @@index([started_at(sort: Desc)])
  @@index([status])
  @@map("health_check_runs")
}

// 개별 체크 결과. run_id당 수십~수백 건.
// category: auth/api/page/security/data/perf (향후 확장)
// onDelete: Cascade → Run 삭제 시 결과도 일괄 정리
model HealthCheckResult {
  id            BigInt   @id @default(autoincrement())
  run_id        BigInt
  category      String   @db.VarChar // auth/api/page/security/data/perf
  name          String   @db.VarChar
  target_url    String?  @db.VarChar
  passed        Boolean
  status_code   Int?
  duration_ms   Int?
  error_message String?  @db.Text
  created_at    DateTime @default(now()) @db.Timestamp(6)

  run HealthCheckRun @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@index([run_id])
  @@index([passed, created_at(sort: Desc)])
  @@map("health_check_results")
}

// ============================================================
// Phase 12-A — 시즌 통계 / 슛존 / 스카우팅 (2026-04-30)
// 통합 마이그레이션: 12-1 테이블만 추가, 집계/UI 는 Phase 13+
// ============================================================

// Phase 12-A: 사용자 × 시즌 누적 집계 (랭킹 페이지 / 마이페이지 시즌 카드 용)
// 한 유저가 한 시즌에 한 행 (@@unique user_id+season_year)
// avg_rating: game_player_ratings 평균 (1.00~5.00)
// rank_position: 시즌 순위 (NULL = 미집계 — 배치 잡이 채움)
model UserSeasonStat {
  id            BigInt   @id @default(autoincrement())
  user_id       BigInt
  season_year   Int // 시즌 연도 (예: 2026)
  season_label  String?  @db.VarChar(50) // 표시용 라벨 ("2026 시즌" 등)
  games_played  Int      @default(0)
  wins          Int      @default(0)
  losses        Int      @default(0)
  avg_rating    Decimal? @db.Decimal(3, 2) // 1.00 ~ 5.00
  mvp_count     Int      @default(0)
  rank_position Int? // 시즌 종합 순위 (NULL = 미집계)
  total_minutes Int      @default(0)
  total_xp      Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, season_year])
  @@index([user_id])
  @@index([season_year])
  @@map("user_season_stats")
}

// Phase 12-A: 슛존 통계 (Phase 13+ 에서 집계 잡 + UI 추가 예정)
// zone_code: "RA"(restricted area) / "PAINT" / "MID_LEFT" / "MID_RIGHT" / "3PT_CORNER_L" 등
// efficiency: made / attempts (0.0000 ~ 1.0000) — 트리거 또는 배치로 채움
model ShotZoneStat {
  id          BigInt   @id @default(autoincrement())
  user_id     BigInt
  season_year Int
  zone_code   String   @db.VarChar(20) // RA, PAINT, MID_LEFT, ...
  attempts    Int      @default(0)
  made        Int      @default(0)
  efficiency  Decimal? @db.Decimal(5, 4) // 0.0000 ~ 1.0000
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, season_year, zone_code])
  @@index([user_id])
  @@map("shot_zone_stats")
}

// Phase 12-A: 스카우팅 리포트 (Phase 13+ UI / API 추가 예정)
// 한 평가자가 한 대상에게 한 행만 작성 (@@unique target+evaluator)
// is_anonymous: 기본 true — 평가자 신원 비공개. 대상에게는 평가 내용만 보임
model ScoutingReport {
  id                BigInt   @id @default(autoincrement())
  target_user_id    BigInt // 평가 대상
  evaluator_user_id BigInt // 평가자 (작성자)
  strengths         String?  @db.Text
  weaknesses        String?  @db.Text
  rating            Int? // 1~5 종합 평점
  comment           String?  @db.Text
  is_anonymous      Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamp(6)

  target_user    User @relation("ScoutingTarget", fields: [target_user_id], references: [id], onDelete: Cascade)
  evaluator_user User @relation("ScoutingEvaluator", fields: [evaluator_user_id], references: [id], onDelete: Cascade)

  @@unique([target_user_id, evaluator_user_id])
  @@index([target_user_id])
  @@map("scouting_reports")
}

// 2026-05-04: 알기자 (BDR NEWS) 기사 사진 — 매치당 N장
// Phase 1 (MVP) = 운영자 admin/news 에서 수동 업로드 + 매치 dropdown 선택
// Phase 2 큐 = EXIF 메타 (촬영 시각/GPS) 기반 자동 매치 추천
// Phase 3 큐 = AI Vision 기반 사진 자동 분류 (덩크/3점/MVP 시상 등)
//
// 노출 위치 (3곳):
//   - community/[id] 본문 — Hero (is_hero=true 1장) + 갤러리 (display_order)
//   - news/match/[matchId] deep link — 동일
//   - community list 카드 — 첫 사진 썸네일 우측
//
// 저장: Supabase Storage `news-photos` bucket. URL = public, storage_path = bucket 내 경로 (삭제용).
model news_photo {
  id            BigInt   @id @default(autoincrement())
  match_id      BigInt // tournamentMatch.id (1:N)
  url           String   @db.VarChar // Supabase Storage public URL
  storage_path  String   @db.VarChar // bucket 내 경로 (삭제 시 사용)
  width         Int?
  height        Int?
  size_bytes    Int?
  is_hero       Boolean  @default(false) // 대표 사진 — 매치당 1개 (application level 보장)
  display_order Int      @default(0) // 갤러리 정렬 (0 부터, 작은 수가 먼저)
  uploaded_by   BigInt // User.id (감사 추적)
  caption       String?  @db.Text // 운영자 설명 (옵션)
  exif_meta     Json? // EXIF metadata (Phase 2 EXIF 매핑 용 — 촬영시각/GPS/카메라)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @updatedAt @db.Timestamp(6)

  match TournamentMatch @relation(fields: [match_id], references: [id], onDelete: Cascade)
  user  User            @relation("NewsPhotoUploader", fields: [uploaded_by], references: [id], onDelete: NoAction)

  @@index([match_id])
  @@index([match_id, is_hero])
  @@index([match_id, display_order])
  @@map("news_photos")
}

// 2026-05-04: 알기자 (BDR NEWS) 자동 발행 시도 기록 — silent fail 모니터링
// 자동 트리거 (auto-publish-match-brief.ts) 의 publishPhase1Summary / publishPhase2MatchBrief
// 가 매번 결과 INSERT (success/failed/skipped). 사후 진단 + admin 모니터링 큐 활용.
//
// status:
//   - "success"   : 정상 완료 (Phase 1 = summary_brief UPDATE / Phase 2 = community_post INSERT)
//   - "skipped"   : 멱등성 skip (이미 결과 존재 또는 매치 not_completed)
//   - "failed"    : LLM 호출 실패 / 검증 실패 / DB 에러
//
// reason:
//   - success/skipped: 짧은 메모 (예: "already_exists", "not_completed", "ok")
//   - failed: 에러 메시지 / validate-brief reason / HTTP status
//
// 정책: 매번 INSERT (UPDATE X) — append-only audit log. 30일+ 오래된 기록 cleanup 큐.
model news_publish_attempt {
  id         BigInt   @id @default(autoincrement())
  match_id   BigInt
  phase      String   @db.VarChar // "phase1-section" | "phase2-match"
  status     String   @db.VarChar // "success" | "skipped" | "failed"
  reason     String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamp(6)

  match TournamentMatch @relation(fields: [match_id], references: [id], onDelete: Cascade)

  @@index([match_id])
  @@index([status, created_at])
  @@index([phase, status])
  @@map("news_publish_attempts")
}
