model community_posts {
  id                   BigInt                 @id @default(autoincrement())
  user_id              BigInt
  title                String                 @db.VarChar
  content              String?
  category             String?                @default("general") @db.VarChar
  view_count           Int?                   @default(0)
  status               String?                @default("published") @db.VarChar
  created_at           DateTime               @db.Timestamp(6)
  updated_at           DateTime               @db.Timestamp(6)
  comments_count       Int                    @default(0)
  public_id            String                 @unique(map: "index_community_posts_on_public_id") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  team_id              BigInt?
  latitude             Decimal?               @db.Decimal(10, 7)
  longitude            Decimal?               @db.Decimal(10, 7)
  location_name        String?                @db.VarChar
  location_address     String?                @db.VarChar
  price                Int?                   @default(0)
  negotiable           Boolean?               @default(false)
  share_contact        Boolean?               @default(false)
  trade_status         String?                @default("available") @db.VarChar
  images               Json? // 이미지 URL 배열 + 카페 메타 (cafe_source_id, cafe_author, cafe_comments)
  likes_count          Int                    @default(0)
  author_nickname      String?                @db.VarChar(255) // 카페 크롤링 글쓴이 닉네임
  // 2026-05-03: 알기자 (BDR NEWS AI) Phase 2 — 매치/라운드/일자 종합 기사 메타.
  // 알기자 게시물만 set, 다른 게시물 모두 null. category="news" 알기자 게시물 식별용.
  // FK는 NoAction (매치 삭제 시 게시물 보존, period_key는 round_id 또는 "YYYY-MM-DD")
  tournament_match_id  BigInt? // 매치 단신 (period_type="match")
  tournament_id        String?                @db.Uuid // 모든 알기자 게시물 (대회 컨텍스트)
  period_type          String?                @db.VarChar(16) // "match" | "round" | "daily"
  period_key           String?                @db.VarChar(64) // round_id 또는 "YYYY-MM-DD"
  users                User                   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_0b2d1de074")
  teams                Team?                  @relation(fields: [team_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_e4a581c07d")
  community_post_likes community_post_likes[]

  @@index([category], map: "index_community_posts_on_category")
  @@index([category, created_at], map: "index_community_posts_on_category_and_created")
  @@index([created_at], map: "index_community_posts_on_created_at")
  @@index([status], map: "index_community_posts_on_status")
  @@index([team_id], map: "index_community_posts_on_team_id")
  @@index([user_id], map: "index_community_posts_on_user_id")
  @@index([tournament_match_id], map: "index_community_posts_on_tournament_match_id")
  @@index([tournament_id], map: "index_community_posts_on_tournament_id")
  @@index([period_type, period_key], map: "index_community_posts_on_period")
}

// 커뮤니티 게시글 좋아요 테이블 (유저당 게시글 1회만 좋아요 가능)
model community_post_likes {
  id                BigInt          @id @default(autoincrement())
  community_post_id BigInt
  user_id           BigInt
  created_at        DateTime        @db.Timestamp(6)
  community_posts   community_posts @relation(fields: [community_post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             User            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([community_post_id, user_id], map: "index_community_post_likes_on_post_and_user")
  @@index([user_id], map: "index_community_post_likes_on_user_id")
}

// 댓글 좋아요 테이블: 유저당 댓글 1회 좋아요
model comment_likes {
  id         BigInt   @id @default(autoincrement())
  comment_id BigInt // 대상 댓글
  user_id    BigInt // 좋아요 누른 유저
  created_at DateTime @db.Timestamp(6)
  comments   comments @relation(fields: [comment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([comment_id, user_id], map: "index_comment_likes_on_comment_and_user")
  @@index([user_id], map: "index_comment_likes_on_user_id")
}

// 팔로우 테이블: follower가 following을 팔로우
model follows {
  id           BigInt   @id @default(autoincrement())
  follower_id  BigInt // 팔로우 하는 사람
  following_id BigInt // 팔로우 당하는 사람
