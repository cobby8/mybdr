model games {
  id                   BigInt              @id @default(autoincrement())
  game_id              String              @unique(map: "index_games_on_game_id") @db.VarChar
  uuid                 String?             @unique(map: "index_games_on_uuid") @db.Uuid
  title                String?             @db.VarChar
  game_type            Int                 @default(0)
  description          String?
  organizer_id         BigInt
  court_id             BigInt?
  city                 String?             @db.VarChar
  district             String?             @db.VarChar
  venue_name           String?             @db.VarChar
  venue_address        String?             @db.VarChar
  scheduled_at         DateTime            @db.Timestamp(6)
  ended_at             DateTime?           @db.Timestamp(6)
  duration_hours       Int?                @default(2)
  max_participants     Int?                @default(10)
  min_participants     Int?                @default(4)
  current_participants Int?                @default(0)
  fee_per_person       Int?                @default(0)
  skill_level          String?             @default("all") @db.VarChar
  uniform_home_color   String?             @default("#FF0000") @db.VarChar
  uniform_away_color   String?             @default("#0000FF") @db.VarChar
  requirements         String?
  notes                String?
  allow_guests         Boolean?            @default(true)
  status               Int                 @default(0)
  contact_phone        String?             @db.VarChar(20)
  entry_fee_note       String?             @db.VarChar(100)
  metadata             Json?               @default("{}")
  author_nickname      String?             @db.VarChar(255)
  template_id          BigInt?
  cloned_from_id       BigInt?
  is_recurring         Boolean?            @default(false)
  recurrence_rule      String?             @db.VarChar
  applications_count   Int?                @default(0)
  views_count          Int?                @default(0)
  // Phase 10-1 — 경기 종료 후 운영자가 확정한 최종 MVP (game_reports 집계 결과 또는 운영자 수동 지정)
  final_mvp_user_id    BigInt?
  created_at           DateTime            @db.Timestamp(6)
  updated_at           DateTime            @db.Timestamp(6)
  game_applications    game_applications[]
  game_templates       game_templates?     @relation(fields: [template_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_2188646eed")
  courts               courts?             @relation(fields: [court_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_bca389c44d")
  games                games?              @relation("gamesTogames", fields: [cloned_from_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_d09f1fe2ce")
  other_games          games[]             @relation("gamesTogames")
  users                User                @relation(fields: [organizer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_f7c3e2a7f2")
  // Phase 10-1 — 최종 MVP 사용자 관계 (운영자 확정용)
  final_mvp            User?               @relation("games_final_mvp", fields: [final_mvp_user_id], references: [id], onDelete: NoAction)
  // Phase 10-1 — 경기 평가 리포트 (다대일 역참조)
  game_reports         game_reports[]

  @@index([city], map: "index_games_on_city")
  @@index([city, game_type], map: "index_games_on_city_and_game_type")
  @@index([city, scheduled_at], map: "index_games_on_city_and_scheduled_at")
  @@index([cloned_from_id], map: "index_games_on_cloned_from_id")
  @@index([court_id], map: "index_games_on_court_id")
  @@index([game_type], map: "index_games_on_game_type")
  @@index([is_recurring], map: "index_games_on_is_recurring")
  @@index([organizer_id, status], map: "index_games_on_organizer_and_status")
  @@index([organizer_id], map: "index_games_on_organizer_id")
  @@index([scheduled_at], map: "index_games_on_scheduled_at")
  @@index([status], map: "index_games_on_status")
  @@index([status, scheduled_at], map: "index_games_on_status_and_scheduled_at")
  @@index([template_id], map: "index_games_on_template_id")
}

// Phase 10-1 — 경기 평가 리포트 (참가자 1인이 1경기당 1건 작성)
// 1) 전체 평점(overall_rating 1-5)
// 2) MVP 지목(mvp_user_id 선택)
// 3) 동행자별 매너평가/신고는 game_player_ratings에 자식 row로 저장
// status: submitted(제출완료) / draft(임시저장) / reviewed(운영자 검토완료) / dismissed(반려)
model game_reports {
  id               BigInt   @id @default(autoincrement())
  game_id          BigInt
  reporter_user_id BigInt
  overall_rating   Int // 1-5점
  comment          String? // 자유 코멘트
  mvp_user_id      BigInt? // 본인 평가에서 지목한 MVP (없을 수 있음)
  status           String   @default("submitted") @db.VarChar
  created_at       DateTime @default(now()) @db.Timestamp(6)
  updated_at       DateTime @updatedAt @db.Timestamp(6)

  game       games                 @relation(fields: [game_id], references: [id], onDelete: NoAction)
  reporter   User                  @relation("game_reports_reporter", fields: [reporter_user_id], references: [id], onDelete: NoAction)
  mvp_player User?                 @relation("game_reports_mvp", fields: [mvp_user_id], references: [id], onDelete: NoAction)
  ratings    game_player_ratings[]

  // 한 경기에서 한 사람이 한 번만 제출 가능
  @@unique([game_id, reporter_user_id])
  @@index([game_id])
  @@index([status])
}

// Phase 10-1 — 경기 평가 자식 테이블: 리포터가 동행자 1인에 대해 매긴 매너평가/신고
// rating: 1-5점 (1=매우 나쁨, 5=매우 좋음)
// flags: 위반 사유 태그 배열 (예: ["late", "rude", "noshow"]) — PostgreSQL TEXT[]
// is_noshow: 노쇼 여부 별도 boolean (집계 편의)
model game_player_ratings {
  id             BigInt   @id @default(autoincrement())
  game_report_id BigInt
  rated_user_id  BigInt
  rating         Int // 1-5점
  flags          String[] // PostgreSQL TEXT[] — 신고 태그 배열
  is_noshow      Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamp(6)

  // 부모 리포트 삭제 시 함께 삭제 (Cascade)
  report     game_reports @relation(fields: [game_report_id], references: [id], onDelete: Cascade)
  rated_user User         @relation("game_player_ratings_rated", fields: [rated_user_id], references: [id], onDelete: NoAction)

  // 한 리포트에서 같은 사람을 두 번 평가하지 못함
  @@unique([game_report_id, rated_user_id])
  @@index([rated_user_id])
}

