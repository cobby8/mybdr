  following    User     @relation("user_following", fields: [following_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([follower_id, following_id], map: "index_follows_on_follower_and_following")
  @@index([following_id], map: "index_follows_on_following_id")
}

