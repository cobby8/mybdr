model court_infos {
  id                     BigInt                   @id @default(autoincrement())
  user_id                BigInt
  name                   String                   @db.VarChar
  description            String?
  address                String                   @db.VarChar
  city                   String                   @db.VarChar
  district               String?                  @db.VarChar
  latitude               Decimal                  @db.Decimal(10, 7)
  longitude              Decimal                  @db.Decimal(10, 7)
  court_type             String                   @default("outdoor") @db.VarChar
  hoops_count            Int?
  surface_type           String?                  @db.VarChar
  is_free                Boolean?
  fee                    Decimal?                 @db.Decimal(10, 0)
  operating_hours        Json?                    @default("{}")
  facilities             Json?                    @default("[]")
  status                 String                   @default("active") @db.VarChar
  reviews_count          Int                      @default(0)
  average_rating         Decimal?                 @default(0.0) @db.Decimal(3, 2)
  checkins_count         Int                      @default(0)
  has_lighting           Boolean?                 @default(false)
  photo_url              String?                  @db.VarChar
  data_source            String?                  @db.VarChar
  metadata               Json?                    @default("{}")
  // 야외 코트 확장 필드 (2026-03-28 추가)
  nickname               String?                  @db.VarChar // 별칭 (예: "뚝섬 코트")
  nearest_station        String?                  @db.VarChar // 가까운 역 (예: "뚝섬역 2번 출구 도보 5분")
  court_size             String?                  @db.VarChar // fullcourt, halfcourt, 3x3
  hoop_height            Float? // 골대 높이 (cm)
  lighting_until         String?                  @db.VarChar // 조명 종료 시간 (예: "23:00")
  has_restroom           Boolean?                 @default(false) // 화장실 유무
  has_parking            Boolean?                 @default(false) // 주차장 유무
  rental_available       Boolean?                 @default(false) // 대관 가능 여부
  rental_url             String?                  @db.VarChar // 대관 신청 URL
  // 코트 대관 (Phase A): "none"=대관 미지원, "external"=rental_url 외부 안내, "internal"=시스템 내 예약
  // 기본값 "none" 으로 기존 코트는 모두 대관 미지원 상태 유지
  booking_mode           String                   @default("none") @db.VarChar
  // 시간당 대관료 (원 단위). null 이면 운영자가 미설정 → UI에서 "요금 미설정" 표시
  // 기존 fee 필드는 "전체 대관" 의미였을 수 있으므로 분리 (Phase A 는 항상 final_amount=0 무료)
  booking_fee_per_hour   Decimal?                 @db.Decimal(10, 0)
  kakao_place_id         String?                  @db.VarChar // 카카오 장소 ID
  kakao_place_url        String?                  @db.VarChar // 카카오 장소 URL
  avg_rating             Float? // 카카오 평균 평점
  review_count           Int                      @default(0) // 카카오 리뷰 수
  verified               Boolean                  @default(false) // 수동 큐레이션 검증 여부
  created_at             DateTime                 @db.Timestamp(6)
  updated_at             DateTime                 @db.Timestamp(6)
  court_checkins         court_checkins[]
  court_sessions         court_sessions[]
  users                  User                     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_d006c2c973")
  reports_count          Int                      @default(0) // 활성 상태 제보 수
  court_reviews          court_reviews[]
  court_reports          court_reports[]
  court_edit_suggestions court_edit_suggestions[]
  pickup_games           pickup_games[]
  court_ambassadors      court_ambassadors[]
  court_events           court_events[]
  // 코트 대관 (Phase A): 본 코트의 모든 예약/블록 슬롯
  court_bookings         court_bookings[]

  @@index([average_rating], map: "index_court_infos_on_average_rating")
  @@index([city], map: "index_court_infos_on_city")
  @@index([city, district], map: "index_court_infos_on_city_and_district")
  @@index([court_type], map: "index_court_infos_on_court_type")
  @@index([is_free], map: "index_court_infos_on_is_free")
  @@index([latitude, longitude], map: "index_court_infos_on_latitude_and_longitude")
  @@index([status], map: "index_court_infos_on_status")
  @@index([court_type, is_free], map: "index_court_infos_on_type_and_free")
  @@index([user_id], map: "index_court_infos_on_user_id")
}

// 코트 대관 (Phase A — MVP 무료 대관)
// status 흐름:
//   pending(슬롯 잠금, 결제 도입 시 사용) → confirmed(예약 확정) → cancelled / refunded / completed(이용 종료)
//   blocked = 운영자가 직접 차단(점검·우천 등)한 슬롯. user_id 에 운영자 본인이 들어감
// Phase A 는 결제 미도입 → POST 시점에 즉시 confirmed 로 생성
// Phase B 에서 토스페이먼츠 결제 도입 시 pending 잠금 + payment_id 연결
model court_bookings {
  id                  BigInt    @id @default(autoincrement())
  court_info_id       BigInt
  user_id             BigInt // 예약자(또는 blocked 슬롯의 운영자)
  start_at            DateTime  @db.Timestamp(6) // 시작 (1시간 단위 권장)
  end_at              DateTime  @db.Timestamp(6) // 종료 (start_at + duration_hours * 1h)
  duration_hours      Int // 1~4 (시안)
  // 이용 목적: pickup(픽업경기) | team(팀 훈련) | scrim(스크림) | private(개인연습) | block(운영자 차단)
  purpose             String    @default("pickup") @db.VarChar
  expected_count      Int? // 예상 인원 (시안: 1~30)
  amount              Decimal   @default(0) @db.Decimal(10, 0) // 기본 대관료 (원)
  discount_amount     Decimal?  @default(0) @db.Decimal(10, 0) // BDR+ 할인 등 (Phase D)
  final_amount        Decimal   @default(0) @db.Decimal(10, 0) // 최종 결제 금액 (Phase A=0)
  platform_fee        Decimal?  @default(0) @db.Decimal(10, 0) // 플랫폼 수수료 (Phase B)
  status              String    @default("confirmed") @db.VarChar
  payment_id          BigInt? // payments.id FK (Phase B 에서 결제 연결)
  cancellation_reason String?
  cancelled_at        DateTime? @db.Timestamp(6)
  refunded_at         DateTime? @db.Timestamp(6)
  created_at          DateTime  @default(now()) @db.Timestamp(6)
  updated_at          DateTime  @updatedAt @db.Timestamp(6)

  court court_infos @relation(fields: [court_info_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user  User        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // 슬롯 충돌 검사용 핵심 인덱스 — (court, start_at) 범위 쿼리 가속
  @@index([court_info_id, start_at])
  // 내 예약 목록 조회용
  @@index([user_id, status])
  // 운영자 대시보드용
  @@index([status, created_at])
  @@map("court_bookings")
}

model court_reviews {
  id                   BigInt      @id @default(autoincrement())
  court_info_id        BigInt
  user_id              BigInt
  rating               Int
  content              String?
  likes_count          Int         @default(0)
  status               String      @default("published") @db.VarChar
  is_checkin           Boolean     @default(false)
  checkin_latitude     Decimal?    @db.Decimal(10, 7)
  checkin_longitude    Decimal?    @db.Decimal(10, 7)
  metadata             Json?       @default("{}")
  // Phase 3: 5항목 세부 별점 (nullable로 기존 데이터 보존)
  facility_rating      Int? // 시설 별점 1~5
  accessibility_rating Int? // 접근성 별점 1~5
  surface_rating       Int? // 바닥상태 별점 1~5
  lighting_rating      Int? // 조명 별점 1~5
  atmosphere_rating    Int? // 분위기 별점 1~5
  photos               Json        @default("[]") // 사진 URL 배열 (최대 3장)
  created_at           DateTime    @db.Timestamp(6)
  updated_at           DateTime    @db.Timestamp(6)
  court_infos          court_infos @relation(fields: [court_info_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_898a2b5629")
  users                User        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_af1069aa7a")

  @@unique([court_info_id, user_id], map: "idx_court_reviews_court_user_unique") // 한 코트에 유저당 1개 리뷰
  @@index([court_info_id], map: "index_court_reviews_on_court_info_id")
  @@index([is_checkin], map: "index_court_reviews_on_is_checkin")
  @@index([rating], map: "index_court_reviews_on_rating")
  @@index([status], map: "index_court_reviews_on_status")
  @@index([user_id], map: "index_court_reviews_on_user_id")
}

// Phase 3: 코트 상태 제보 — 골대 파손, 바닥 손상 등
model court_reports {
  id            BigInt      @id @default(autoincrement())
  court_info_id BigInt
  user_id       BigInt
  report_type   String      @db.VarChar // hoop_broken, surface_damaged 등
  description   String? // 상세 설명
  photos        Json        @default("[]") // 사진 URL 배열
  status        String      @default("active") @db.VarChar // active, resolved, dismissed
  resolved_at   DateTime?   @db.Timestamp(6) // 해결 처리 시각
  resolved_by   BigInt? // 해결 처리한 관리자 ID
  created_at    DateTime    @default(now()) @db.Timestamp(6)
  updated_at    DateTime    @updatedAt @db.Timestamp(6)
  court_infos   court_infos @relation(fields: [court_info_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         User        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([court_info_id, status], map: "idx_court_reports_court_status")
  @@index([user_id], map: "idx_court_reports_user")
}

// 유저 위키 — 코트 정보 수정 제안 (위키피디아식 편집)
// reports(119 신고)와 구분: suggestions는 "바닥재 우레탄", "조명 23시까지" 같은 정보 보정
model court_edit_suggestions {
  id            BigInt    @id @default(autoincrement())
  court_info_id BigInt // 대상 코트
  user_id       BigInt // 제안자
  changes       Json // {"surface_type":{"old":null,"new":"urethane"}, ...}
  reason        String    @db.VarChar // 수정 사유 (필수)
  status        String    @default("pending") @db.VarChar // pending | approved | rejected
  reviewed_by   BigInt? // 심사한 관리자 ID
  reviewed_at   DateTime? @db.Timestamp(6) // 심사 시각
  review_note   String? // 관리자 메모 (거절 사유 등)
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime  @updatedAt @db.Timestamp(6)

  court_infos court_infos @relation(fields: [court_info_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       User        @relation("suggestion_submitter", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewer    User?       @relation("suggestion_reviewer", fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([court_info_id, status], map: "idx_court_edit_suggestions_court_status")
  @@index([user_id], map: "idx_court_edit_suggestions_user")
  @@index([status], map: "idx_court_edit_suggestions_status")
}

// 게이미피케이션 뱃지 — 유저가 획득한 뱃지 기록
model user_badges {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  badge_type String   @db.VarChar // court_explorer, streak_7, level_up 등
  badge_name String   @db.VarChar // "동네 농구인", "7일 연속!" 등
  badge_data Json     @default("{}") // 추가 메타데이터 (달성 코트 수 등)
  earned_at  DateTime @default(now()) @db.Timestamp(6)

  users User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, badge_type]) // 같은 뱃지 중복 방지
  @@index([user_id])
}

// 체크인/체크아웃 세션 — 혼잡도 + XP 시스템용
model court_sessions {
  id               BigInt    @id @default(autoincrement())
  user_id          BigInt
  court_id         BigInt
  checked_in_at    DateTime  @default(now()) @db.Timestamp(6)
  checked_out_at   DateTime? @db.Timestamp(6)
  duration_minutes Int?
  checkin_method   String    @default("manual") @db.VarChar // manual, proximity, qr
  checkin_lat      Float?
  checkin_lng      Float?
  xp_earned        Int       @default(0)

  users       User        @relation(fields: [user_id], references: [id])
  court_infos court_infos @relation(fields: [court_id], references: [id])

  @@index([court_id, checked_in_at])
  @@index([user_id, checked_in_at])
  @@index([court_id], map: "idx_court_sessions_court") // 코트별 세션 조회
  @@index([user_id], map: "idx_court_sessions_user") // 유저별 세션 조회
  @@index([checked_in_at], map: "idx_court_sessions_checkin_time") // 시간 범위 필터
  @@index([user_id, checked_out_at], map: "idx_court_sessions_user_checkout") // 활성 세션 조회
}

model courts {
