generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                                                                        BigInt                        @id @default(autoincrement())
  email                                                                     String                        @unique(map: "index_users_on_email") @db.VarChar
  passwordDigest                                                            String                        @map("password_digest") @db.VarChar
  name                                                                      String?                       @db.VarChar
  nickname                                                                  String?                       @db.VarChar
  phone                                                                     String?                       @db.VarChar
  profile_image                                                             String?                       @db.VarChar
  position                                                                  String?                       @db.VarChar
  height                                                                    Int?
  weight                                                                    Int?
  birth_date                                                                DateTime?                     @db.Date
  // DB drift 복원: 기존 users.gender 컬럼 유지 (schema 누락분)
  gender                                                                    String?                       @db.VarChar
  city                                                                      String?                       @db.VarChar
  district                                                                  String?                       @db.VarChar
  bio                                                                       String?
  membershipType                                                            Int                           @default(0) @map("membership_type")
  subscription_started_at                                                   DateTime?                     @db.Timestamp(6)
  subscription_expires_at                                                   DateTime?                     @db.Timestamp(6)
  subscription_status                                                       String?                       @default("inactive") @db.VarChar
  bank_name                                                                 String?                       @db.VarChar
  bank_code                                                                 String?                       @db.VarChar
  account_number                                                            String?                       @db.VarChar
  account_holder                                                            String?                       @db.VarChar
  toss_id                                                                   String?                       @db.VarChar
  isAdmin                                                                   Boolean?                      @default(false) @map("is_admin")
  status                                                                    String?                       @default("active") @db.VarChar
  suspended_at                                                              DateTime?                     @db.Timestamp(6)
  evaluation_rating                                                         Decimal?                      @default(0.0) @db.Decimal(3, 2)
  total_games_hosted                                                        Int?                          @default(0)
  total_games_participated                                                  Int?                          @default(0)
  last_login_at                                                             DateTime?                     @db.Timestamp(6)
  createdAt                                                                 DateTime                      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                                                                 DateTime                      @updatedAt @map("updated_at") @db.Timestamp(6)
  public_id                                                                 String                        @unique(map: "index_users_on_public_id") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider                                                                  String?                       @db.VarChar
  uid                                                                       String?                       @db.VarChar
  oauth_token                                                               String?                       @db.VarChar
  oauth_expires_at                                                          DateTime?                     @db.Timestamp(6)
  profile_image_url                                                         String?                       @db.VarChar
  prefer_admin_mode                                                         Boolean?                      @default(false)
  tutorial_completed_teams                                                  Boolean                       @default(false)
  tutorial_completed_tournaments                                            Boolean                       @default(false)
  tutorial_completed_games                                                  Boolean                       @default(false)
  tutorial_completed_community                                              Boolean                       @default(false)
  preferred_divisions                                                       Json                          @default("[]")
  preferred_board_categories                                                Json                          @default("[]")
  preferred_game_types                                                      Json                          @default("[]")
  // 맞춤 지역/요일/시간대/실력 (JSON 배열로 저장)
  preferred_regions                                                         Json                          @default("[]")
  preferred_days                                                            Json                          @default("[]")
  preferred_time_slots                                                      Json                          @default("[]")
  preferred_skill_levels                                                    Json                          @default("[]")
  // 2026-05-02: D-6 EditProfile §2 + §3 + §4 박제 활성화 (사용자 옵션 B 채택)
  dominant_hand                                                             String?                       @db.VarChar
  skill_level                                                               String?                       @db.VarChar
  strengths                                                                 Json                          @default("[]")
  privacy_settings                                                          Json                          @default("{}")
  instagram_url                                                             String?                       @db.VarChar
  youtube_url                                                               String?                       @db.VarChar
  // 맞춤 성별 필터 (["male","female","mixed"] 등의 JSON 배열)
  preferred_gender                                                          Json                          @default("[]") @map("preferred_gender")
  // 숨긴 메뉴 slug 배열 (예: ["rankings", "organizations"]) — 사이드/슬라이드 메뉴에서 숨김 처리
  hidden_menus                                                              Json                          @default("[]") @map("hidden_menus")
  // 맞춤 보기 토글 ON/OFF 상태를 DB에 저장 (기본 false)
  // SQL: ALTER TABLE users ADD COLUMN prefer_filter_enabled BOOLEAN NOT NULL DEFAULT false;
  prefer_filter_enabled                                                     Boolean                       @default(false)
  onboarding_step                                                           Int                           @default(0)
  profile_completed                                                         Boolean                       @default(false)
  profileReminderShownAt                                                    DateTime?                     @map("profile_reminder_shown_at") @db.Timestamp(6)
  // 2026-05-01 — 본인 선호 등번호 + 선출 여부.
  // 회원가입 시 입력 X (선택). 대회 출전 신청 시 두 필드 모두 필수 (차단 검증).
  // 본인 EditProfile §1 기본정보 에서 입력 / 추후 본인인증 시스템 자동입력 큐 (별도)
  default_jersey_number                                                     Int?                          @map("default_jersey_number")
  is_elite                                                                  Boolean?                      @default(false) @map("is_elite")
  admin_logs                                                                admin_logs[]
  board_favorites                                                           board_favorites[]
  comments                                                                  comments[]
  community_posts                                                           community_posts[]
  community_post_likes                                                      community_post_likes[]
  comment_likes                                                             comment_likes[]
  court_checkins                                                            court_checkins[]
  court_infos                                                               court_infos[]
  court_reviews                                                             court_reviews[]
  court_sessions                                                            court_sessions[]
  game_applications                                                         game_applications[]
  game_templates                                                            game_templates[]
  games                                                                     games[]
  marketplace_items                                                         marketplace_items[]
  marketplace_phone_requests_marketplace_phone_requests_seller_idTousers    marketplace_phone_requests[]  @relation("marketplace_phone_requests_seller_idTousers")
  marketplace_phone_requests_marketplace_phone_requests_requester_idTousers marketplace_phone_requests[]  @relation("marketplace_phone_requests_requester_idTousers")
  marketplace_wishlists                                                     marketplace_wishlists[]
  memory_cards                                                              memory_cards[]
  notifications                                                             notifications[]
  payments                                                                  payments[]
  posts                                                                     posts[]
  suggestions_suggestions_responded_by_idTousers                            suggestions[]                 @relation("suggestions_responded_by_idTousers")
  suggestions_suggestions_assigned_to_idTousers                             suggestions[]                 @relation("suggestions_assigned_to_idTousers")
  suggestions_suggestions_user_idTousers                                    suggestions[]                 @relation("suggestions_user_idTousers")
  team_join_requests_team_join_requests_user_idTousers                      team_join_requests[]          @relation("team_join_requests_user_idTousers")
  team_join_requests_team_join_requests_processed_by_idTousers              team_join_requests[]          @relation("team_join_requests_processed_by_idTousers")
  team_member_histories_team_member_histories_user_idTousers                team_member_histories[]       @relation("team_member_histories_user_idTousers")
  team_member_histories_team_member_histories_processed_by_idTousers        team_member_histories[]       @relation("team_member_histories_processed_by_idTousers")
  teamMembers                                                               TeamMember[]
  teams_teams_manager_idTousers                                             Team[]                        @relation("teams_manager_idTousers")
  teams_teams_captain_idTousers                                             Team[]                        @relation("teams_captain_idTousers")
  tournamentAdminMembers                                                    TournamentAdminMember[]
  tournament_matches                                                        TournamentMatch[]
  tournament_series                                                         tournament_series[]
  tournament_team_players                                                   TournamentTeamPlayer[]
  tournament_teams                                                          TournamentTeam[]
  tournaments_tournaments_organizer_idTousers                               Tournament[]                  @relation("tournaments_organizer_idTousers")
  tournaments_tournaments_mvp_player_idTousers                              Tournament[]                  @relation("tournaments_mvp_player_idTousers")
  user_favorite_courts                                                      user_favorite_courts[]
  user_subscriptions                                                        user_subscriptions[]
  bracket_versions_created                                                  tournament_bracket_versions[] @relation("bracket_version_creator")
  bracket_versions_approved                                                 tournament_bracket_versions[] @relation("bracket_version_approver")
  quickMenuItems                                                            String[]                      @default(["find_game", "my_team", "tournaments", "pickup"]) @map("quick_menu_items")
  recorderAssignments                                                       tournament_recorders[]        @relation("TournamentRecorder")
  recorderAssigned                                                          tournament_recorders[]        @relation("TournamentRecorderAssigner")
  match_events_recorded                                                     match_events[]                @relation("MatchEventRecorder")
  match_events_undone                                                       match_events[]                @relation("MatchEventUndoner")
  match_audits_changed                                                      tournament_match_audits[]     @relation("MatchAuditChanger")
  // 팔로우 시스템: 나를 팔로우하는 사람들 / 내가 팔로우하는 사람들
  followers                                                                 follows[]                     @relation("user_followers")
  following                                                                 follows[]                     @relation("user_following")
  court_reports                                                             court_reports[]
  // 위키 수정 제안: 작성자 / 심사자 2가지 관계
  court_edit_suggestions_submitted                                          court_edit_suggestions[]      @relation("suggestion_submitter")
  court_edit_suggestions_reviewed                                           court_edit_suggestions[]      @relation("suggestion_reviewer")
  // 게이미피케이션: XP/레벨/스트릭 (Phase 4)
  xp                                                                        Int                           @default(0)
  level                                                                     Int                           @default(1)
  streak_count                                                              Int                           @default(0)
  streak_last_date                                                          DateTime?                     @db.Date
  user_badges                                                               user_badges[]
  // Phase 5: 픽업게임 — 방장 / 참가자 2가지 관계
  pickup_games_hosted                                                       pickup_games[]                @relation("pickup_host")
  pickup_participations                                                     pickup_participants[]         @relation("pickup_participant")
  // 코트 앰배서더: 해당 유저가 앰배서더로 활동하는 코트들
  court_ambassadors                                                         court_ambassadors[]           @relation("ambassador_user")
  // 3x3 이벤트: 주최자 / 선수 참가
  court_events_organized                                                    court_events[]                @relation("event_organizer")
  court_event_players                                                       court_event_players[]         @relation("event_player")
  // 알림 설정: 유형별 ON/OFF (기본 전체 ON)
  notification_settings                                                     Json?                         @default("{}")
  // 웹 푸시 구독: 유저가 등록한 브라우저 푸시 구독 목록
  push_subscriptions                                                        push_subscriptions[]
  // 비밀번호 재설정: 토큰 + 만료시간
  reset_token                                                               String?                       @db.VarChar
  reset_token_expires                                                       DateTime?                     @db.Timestamp(6)
  // 관리자 세분화 역할: null=일반, "super_admin"/"org_admin"/"content_admin" 등
  // 기존 isAdmin=true → super_admin과 동일하게 취급 (호환성 유지)
  admin_role                                                                String?                       @db.VarChar
  // 단체(Organization) 관계: 소유한 단체 / 멤버로 소속된 단체
  organizations_owned                                                       organizations[]               @relation("org_owner")
  organization_members                                                      organization_members[]
  // 광고 파트너: 소유한 파트너사 / 파트너 멤버
  partners_owned                                                            partners[]                    @relation("partner_owner")
  partner_members                                                           partner_members[]
  // 심판 플랫폼: 1:1 (User 하나당 Referee 0~1). back-relation 1줄만 추가.
  referee                                                                   Referee?
  // 코트 대관 (Phase A): 회원이 예약한 코트 슬롯 + 운영자가 등록한 블록(차단) 슬롯 모두 포함
  // 운영자가 차단 슬롯을 등록할 때도 본 user_id 에 운영자 본인이 들어간다 (status="blocked")
  court_bookings                                                            court_bookings[]

  // Phase 10-1 — 매너 점수 시스템
  // manner_score: game_player_ratings.rating 평균(1.00~5.00). 평가 0건이면 null
  // manner_count: 평가받은 누적 건수 (집계용 캐시)
  manner_score Decimal? @db.Decimal(3, 2)
  manner_count Int      @default(0)

  // Phase 10-1 — 경기 평가/신고 시스템 관계
  // 내가 작성한 리포트 / MVP 지목 받은 횟수 / 평가 받은 항목 / 최종 MVP로 확정된 경기
  game_reports_as_reporter     game_reports[]        @relation("game_reports_reporter")
  game_reports_as_mvp          game_reports[]        @relation("game_reports_mvp")
  game_player_ratings_received game_player_ratings[] @relation("game_player_ratings_rated")
  games_as_final_mvp           games[]               @relation("games_final_mvp")

  // Phase 10-5 — 온보딩 데이터 저장 (UI-only 박제 → 활성화)
  // styles: 플레이 스타일 12종 中 최대 4개 (3점 슈터 / 돌파형 / 포스트업 등)
  // active_areas: 주 활동 지역 18종 (강남 / 서초 / 송파 등)
  // goals: 가입 목표 6종 (friends / fit / skill / compete / team / fun)
  // play_frequency: 농구 빈도 4종 단일 (daily / weekly / monthly / rare)
  // onboarding_completed_at: 완료 시각 — null 이면 setup 위저드 재진입 가능
  styles                  String[]  @default([])
  active_areas            String[]  @default([])
  goals                   String[]  @default([])
  play_frequency          String?   @db.VarChar
  onboarding_completed_at DateTime? @db.Timestamp(6)

  // Phase 10-4 — 팀 팔로우 + 매치 신청 시스템
  // 내가 팔로우 중인 팀들 / 내가 제안자(보통 from_team captain)인 매치 신청
  team_follows                 team_follows[]        @relation("team_follows_user")
  team_match_requests_proposed team_match_requests[] @relation("team_match_requests_proposer")

  // Phase 12-C — 본인인증 (PortOne 또는 외부 KYC 결과)
  // 신규 가입자는 강제 인증 / 기존 사용자는 대회 신청 시점에 인증 (백필 X — 대회 게이트에서 검증)
  // verified_name: 인증 시점의 실명 (User.name 과 별도 — 인증값은 변경 불가)
  // verified_phone: 인증 시점의 휴대폰 번호 (E.164 또는 국내 010-XXXX-XXXX)
  // verified_birth: 인증 시점의 생년월일 (User.birth_date 와 별도)
  // name_verified: 인증 완료 여부 (대회 신청 게이트에서 true 검사)
  // verified_at: 인증 완료 시각 (감사 로그용)
  verified_name  String?   @db.VarChar(100)
  verified_phone String?   @db.VarChar(20)
  verified_birth DateTime? @db.Date
  name_verified  Boolean   @default(false)
  verified_at    DateTime? @db.Timestamp(6)

  // Phase 12-A — 시즌 통계 / 슛존 / 스카우팅 리포트 (12-1 테이블만, UI/집계는 Phase 13+)
  season_stats         UserSeasonStat[]
  shot_zones           ShotZoneStat[]
  scouting_received    ScoutingReport[] @relation("ScoutingTarget")
  scouting_given       ScoutingReport[] @relation("ScoutingEvaluator")
  // 2026-05-04: 알기자 기사 사진 업로드자 역참조
  news_photos_uploaded news_photo[]     @relation("NewsPhotoUploader")

  @@unique([provider, uid], map: "index_users_on_provider_and_uid")
  @@index([createdAt], map: "index_users_on_created_at")
  @@index([membershipType], map: "index_users_on_membership_type")
  @@index([preferred_divisions], map: "index_users_on_preferred_divisions", type: Gin)
  @@index([profile_completed], map: "index_users_on_profile_completed")
  @@index([status], map: "index_users_on_status")
  @@map("users")
}

model Tournament {
  id                                     String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  series_id                              BigInt?
  organizerId                            BigInt                        @map("organizer_id")
  name                                   String                        @db.VarChar
  edition_number                         Int?
  description                            String?
  logo_url                               String?                       @db.VarChar
  banner_url                             String?                       @db.VarChar
  court_bg_url                           String?                       @db.VarChar
  registration_start_at                  DateTime?                     @db.Timestamp(6)
  registration_end_at                    DateTime?                     @db.Timestamp(6)
  startDate                              DateTime?                     @map("start_date") @db.Timestamp(6)
  endDate                                DateTime?                     @map("end_date") @db.Timestamp(6)
  format                                 String?                       @default("single_elimination") @db.VarChar
  maxTeams                               Int?                          @default(16) @map("max_teams")
  min_teams                              Int?                          @default(4)
  team_size                              Int?                          @default(5)
  roster_min                             Int?                          @default(5)
  roster_max                             Int?                          @default(12)
  entry_fee                              Decimal?                      @default(0.0) @db.Decimal(10, 0)
  prize_info                             String?
  prize_distribution                     Json?                         @default("{}")
  rules                                  String?
  game_rules                             Json?                         @default("{}")
  venue_id                               BigInt?
  venue_name                             String?                       @db.VarChar
  venue_address                          String?                       @db.VarChar
  city                                   String?                       @db.VarChar
  district                               String?                       @db.VarChar
  // 대회 관리 확장 필드 (BDR-join 이식)
  organizer                              String?                       @db.VarChar
  host                                   String?                       @db.VarChar
  sponsors                               String?                       @db.VarChar
  game_time                              String?                       @db.VarChar
  game_ball                              String?                       @db.VarChar
  game_method                            String?
  places                                 Json?
  gender                                 String?                       @db.VarChar
  design_template                        String?                       @db.VarChar
  status                                 String?                       @default("draft") @db.VarChar
  teams_count                            Int?                          @default(0)
  matches_count                          Int?                          @default(0)
  views_count                            Int?                          @default(0)
  settings                               Json?                         @default("{}")
  author_nickname                        String?                       @db.VarChar(255)
  is_public                              Boolean?                      @default(true)
  auto_approve_teams                     Boolean?                      @default(false)
  champion_team_id                       BigInt?
  mvp_player_id                          BigInt?
  divisions                              Json                          @default("[]")
  division_tiers                         Json                          @default("[]")
  categories                             Json?                         @default("{}")
  div_caps                               Json?                         @default("{}")
  div_fees                               Json?                         @default("{}")
  allow_waiting_list                     Boolean?                      @default(false)
  waiting_list_cap                       Int?
  fee_notes                              String?
  bank_name                              String?                       @db.VarChar
  bank_account                           String?                       @db.VarChar
  bank_holder                            String?                       @db.VarChar
  createdAt                              DateTime                      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                              DateTime                      @updatedAt @map("updated_at") @db.Timestamp(6)
  primary_color                          String?                       @db.VarChar
  secondary_color                        String?                       @db.VarChar
  apiToken                               String?                       @unique(map: "index_tournaments_on_api_token") @map("api_token") @db.VarChar
  // 2026-05-04: 매치 코드 v4 — 대회 영문 이니셜 2자 + 시즌/회차 2자리 (예: MD21=몰텐배제21회 / HJ02=열혈SEASON2). NULL = backfill 점진 안전, UNIQUE = 동일 short_code 재사용 방지.
  short_code                             String?                       @unique @db.VarChar(7)
  // 2026-05-04: 매치 코드 v4 — 17시도 영문약어 2자 (SE/BS/DG/IC/GJ/DJ/US/SJ/GG/GW/CB/CN/JB/JN/GB/GN/JJ). city/district 자유 텍스트 → normalizeRegion() 으로 정규화.
  region_code                            String?                       @db.VarChar(2)
  adminMembers                           TournamentAdminMember[]
  tournamentMatches                      TournamentMatch[]
  tournamentSite                         TournamentSite[]
  recorders                              tournament_recorders[]
  siteRegistrations                      site_registrations[]
  tournamentTeams                        TournamentTeam[]
  tournament_bracket_versions            tournament_bracket_versions[]
  teams                                  Team?                         @relation(fields: [champion_team_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_18732ad2a6")
  tournament_series                      tournament_series?            @relation(fields: [series_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_228d987a3d")
  courts                                 courts?                       @relation(fields: [venue_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_4ed1e7dadb")
  users_tournaments_organizer_idTousers  User                          @relation("tournaments_organizer_idTousers", fields: [organizerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_5037ef73fd")
  users_tournaments_mvp_player_idTousers User?                         @relation("tournaments_mvp_player_idTousers", fields: [mvp_player_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_85db3c3f6e")

  @@index([champion_team_id], map: "index_tournaments_on_champion_team_id")
  @@index([divisions], map: "index_tournaments_on_divisions", type: Gin)
  @@index([is_public], map: "index_tournaments_on_is_public")
  @@index([mvp_player_id], map: "index_tournaments_on_mvp_player_id")
  @@index([organizerId, status], map: "index_tournaments_on_organizer_and_status")
  @@index([organizerId], map: "index_tournaments_on_organizer_id")
  @@index([series_id], map: "index_tournaments_on_series_id")
  @@index([startDate], map: "index_tournaments_on_start_date")
  @@index([status], map: "index_tournaments_on_status")
  @@index([status, startDate], map: "index_tournaments_on_status_and_start_date")
  @@index([venue_id], map: "index_tournaments_on_venue_id")
  @@index([city], map: "index_tournaments_on_city")
  @@map("tournaments")
}

model TournamentAdminMember {
  id           BigInt     @id @default(autoincrement())
  userId       BigInt     @map("user_id")
  role         String     @default("admin") @db.VarChar
  permissions  Json?      @default("{}")
  isActive     Boolean?   @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamp(6)
  tournamentId String     @map("tournament_id") @db.Uuid
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_3f7d9c2d9b")
  user         User       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_44decc2910")

  @@index([tournamentId], map: "index_tournament_admin_members_on_tournament_id")
  @@index([tournamentId, role], map: "index_tournament_admin_members_on_tournament_id_and_role")
  @@index([userId], map: "index_tournament_admin_members_on_user_id")
  @@map("tournament_admin_members")
}

model Team {
  id                                                              BigInt                  @id @default(autoincrement())
  uuid                                                            String                  @unique(map: "index_teams_on_uuid") @db.VarChar
  name                                                            String                  @db.VarChar
  // 신규: 영문 팀명 (선택). 국제 대회/영문 검색 매칭용. null 허용, unique 아님.
  name_en                                                         String?                 @db.VarChar
  // 대표 언어 코드 ("ko" | "en"). UI에서 어느 언어를 상단에 크게 보여줄지 결정. 기본값 "ko".
  name_primary                                                    String?                 @default("ko") @db.VarChar(10)
  slug                                                            String?                 @unique(map: "index_teams_on_slug") @db.VarChar
  description                                                     String?
  logoUrl                                                         String?                 @map("logo_url") @db.VarChar
  banner_url                                                      String?                 @db.VarChar
  city                                                            String?                 @db.VarChar
  district                                                        String?                 @db.VarChar
  home_court                                                      String?                 @db.VarChar
  founded_year                                                    Int?
  captainId                                                       BigInt                  @map("captain_id")
  manager_id                                                      BigInt?
  status                                                          String?                 @default("active") @db.VarChar
  is_public                                                       Boolean?                @default(true)
  accepting_members                                               Boolean?                @default(true)
  max_members                                                     Int?                    @default(15)
  settings                                                        Json?                   @default("{}")
  members_count                                                   Int?                    @default(0)
  wins                                                            Int?                    @default(0)
  losses                                                          Int?                    @default(0)
  draws                                                           Int?                    @default(0)
  tournaments_count                                               Int?                    @default(0)
  primaryColor                                                    String?                 @default("#FFFFFF") @map("primary_color") @db.VarChar
  secondaryColor                                                  String?                 @default("#000000") @map("secondary_color") @db.VarChar
  // 2026-04-29: 홈/어웨이 유니폼 색상 분리 도입.
  // - 기존 primary_color/secondary_color 는 하위 호환을 위해 유지 (deprecate 예정)
  // - 신규 등록 시 home_color/away_color 를 사용. 동시에 primary/secondary 에도 동일 값 저장
  // - 기존 데이터: SQL UPDATE 로 home_color = primary_color 백필 (manual SQL 파일 참조)
  home_color                                                      String?                 @db.VarChar(20)
  away_color                                                      String?                 @db.VarChar(20)
  createdAt                                                       DateTime                @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                                                       DateTime                @updatedAt @map("updated_at") @db.Timestamp(6)
  team_code                                                       String?                 @unique(map: "index_teams_on_team_code") @db.VarChar
  auto_accept_members                                             Boolean                 @default(false)
  community_posts                                                 community_posts[]
  team_join_requests                                              team_join_requests[]
  team_member_histories_team_member_histories_team_idToteams      team_member_histories[] @relation("team_member_histories_team_idToteams")
  team_member_histories_team_member_histories_from_team_idToteams team_member_histories[] @relation("team_member_histories_from_team_idToteams")
  team_member_histories_team_member_histories_to_team_idToteams   team_member_histories[] @relation("team_member_histories_to_team_idToteams")
  teamMembers                                                     TeamMember[]
  users_teams_manager_idTousers                                   User?                   @relation("teams_manager_idTousers", fields: [manager_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_93b029b083")
  users_teams_captain_idTousers                                   User                    @relation("teams_captain_idTousers", fields: [captainId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_ecb2d22ad1")
  tournamentTeams                                                 TournamentTeam[]
  tournaments                                                     Tournament[]

  // Phase 10-4 — 팀 팔로우 + 매치 신청 시스템
  // team_follows: 이 팀을 팔로우 중인 회원 목록
  // team_match_requests_received: 이 팀이 받은 매치 신청 (호스트 측)
  // team_match_requests_sent: 이 팀이 보낸 매치 신청 (제안 측)
  team_follows                 team_follows[]        @relation("team_follows_team")
  team_match_requests_received team_match_requests[] @relation("team_match_requests_to")
  team_match_requests_sent     team_match_requests[] @relation("team_match_requests_from")

  @@index([captainId], map: "index_teams_on_captain_id")
  @@index([city], map: "index_teams_on_city")
  @@index([manager_id], map: "index_teams_on_manager_id")
  @@index([name], map: "index_teams_on_name")
  @@index([status], map: "index_teams_on_status")
  @@index([status, city], map: "index_teams_on_status_and_city")
  @@map("teams")
}

// Phase 10-4 — 팀 팔로우
// 이유(왜): 팀 상세 페이지의 "팔로우" 버튼이 phase-9-future-features 5-2 백로그였는데
// 이번 phase 10-4에서 팔로우 기능을 활성화하려면 (team_id, user_id) 1:1 관계가 필요.
// 같은 (team_id, user_id) 조합은 1행만 허용 (@@unique). 언팔로우는 행 삭제로 처리.
// 알림이 필요하지 않은 light action — 토글만 처리 (Phase 10-4 단순화 원칙).
model team_follows {
  id         BigInt   @id @default(autoincrement())
  team_id    BigInt
  user_id    BigInt
  created_at DateTime @default(now()) @db.Timestamp(6)

  team Team @relation("team_follows_team", fields: [team_id], references: [id], onDelete: Cascade)
  user User @relation("team_follows_user", fields: [user_id], references: [id], onDelete: Cascade)

  // 동일 회원이 동일 팀을 두 번 팔로우 못 하게 차단 (UPSERT 단순화에도 사용)
  @@unique([team_id, user_id], map: "index_team_follows_on_team_and_user")
  @@index([user_id], map: "index_team_follows_on_user_id")
  @@index([team_id], map: "index_team_follows_on_team_id")
  @@map("team_follows")
}

// Phase 10-4 — 팀 매치 신청
// 이유(왜): 시안의 "매치 신청" 버튼은 from_team(제안자 측 팀) → to_team(호스트 측 팀)에
// 친선/연습경기 제안을 보내는 흐름. status는 pending/accepted/rejected/cancelled 4종이지만
// 본 phase 10-4에서는 POST(생성)만 구현 (수락/거절은 후속 PATCH 작업).
// to_team 의 captain 에게 알림 전송. 같은 (from→to) pending 중복 차단은 API 단에서 검사.
model team_match_requests {
  id             BigInt    @id @default(autoincrement())
  from_team_id   BigInt
  to_team_id     BigInt
  proposer_id    BigInt
  message        String?
  preferred_date DateTime? @db.Timestamp(6)
  status         String    @default("pending") @db.VarChar
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  updated_at     DateTime  @updatedAt @db.Timestamp(6)

  from_team Team @relation("team_match_requests_from", fields: [from_team_id], references: [id], onDelete: Cascade)
  to_team   Team @relation("team_match_requests_to", fields: [to_team_id], references: [id], onDelete: Cascade)
  proposer  User @relation("team_match_requests_proposer", fields: [proposer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // 호스트 팀의 인박스 정렬용 — to_team_id + status 복합 인덱스
  @@index([to_team_id, status], map: "index_team_match_requests_on_to_team_status")
  @@index([from_team_id], map: "index_team_match_requests_on_from_team_id")
  @@map("team_match_requests")
}

model TeamMember {
