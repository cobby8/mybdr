{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/basketball/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/list/**",
              "components/nav/**",
              "components/overlay/**",
              "components/structure/**",
              "ui_kits/mybdr-web/**",
              "uploads/BDR Design System v4 (1)/assets/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard|Archivo|IBM Plex Mono|Material Symbols Outlined))/i]",
        "message": "Font not provided by the design system. Available: Pretendard, Archivo, IBM Plex Mono, Material Symbols Outlined."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|title|content|icon|key|ref|className|style|children)$/]",
        "message": "<AccordionItem> doesn't accept that prop. Declared props: id, title, content, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|headline|description|partner|image|cta|href|key|ref|className|style|children)$/]",
        "message": "<AdCard> doesn't accept that prop. Declared props: variant, headline, description, partner, image, cta, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:feed|sidebar|list)$/]",
        "message": "<AdCard> variant must be one of 'feed' | 'sidebar' | 'list'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|title|description|children|action|onClose|key|ref|className|style|children)$/]",
